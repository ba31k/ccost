    import curses
except ImportError:            # Windows без windows-curses: report/json работают
    curses = None

# ---------------------------------------------------------------- прайс / цены

# $ за 1M токенов (input, output) — стандартный прайс API
PRICE = {
    "claude-fable-5":            (10, 50),
    "claude-opus-4-8":           (5, 25),
    "claude-opus-4-7":           (5, 25),
    "claude-opus-4-6":           (5, 25),
    "claude-opus-4-5":           (5, 25),
    "claude-sonnet-5":           (3, 15),
    "claude-sonnet-4-6":         (3, 15),
    "claude-haiku-4-5":          (1, 5),
}
CACHE_W_5M = 1.25    # запись в 5-мин ephemeral-кэш = 1.25× input
CACHE_W_1H = 2.0     # запись в 1-час ephemeral-кэш = 2× input
CACHE_READ = 0.10    # чтение из кэша = 0.1× input

ROOT = os.path.expanduser("~/.claude/projects")

TS_FORMATS = ("%Y-%m-%dT%H:%M:%S.%fZ", "%Y-%m-%dT%H:%M:%SZ")


def price_for(model):
    """Цена модели; датированные id (…-20251001) матчатся по префиксу."""
    p = PRICE.get(model)
    if p:
        return p
    for k, v in PRICE.items():
        if model.startswith(k):
            return v
    return None


def cost_of(model, tin, tout, cw, cr, cw1h):
    """None — модели нет в прайсе (стоимость неизвестна)."""
    p = price_for(model)
    if p is None:
        return None
    pin, pout = p
    ci = pin / 1e6
    cw5 = max(cw - cw1h, 0)
    return (tin * ci + tout * pout / 1e6
            + cw5 * ci * CACHE_W_5M + cw1h * ci * CACHE_W_1H
            + cr * ci * CACHE_READ)


def parse_ts(s):
    if not s:
        return 0.0
    for fmt in TS_FORMATS:
        try:
            return datetime.strptime(s, fmt).replace(tzinfo=timezone.utc).timestamp()
        except ValueError:
            continue
    return 0.0


def h(n):
    """Человекочитаемый размер токенов: 1234567 -> 1.2M (без «1000.0K»)."""
    for unit, size in (("B", 1e9), ("M", 1e6), ("K", 1e3)):
        if n >= size * 0.9995:               # 999950 -> 1.0M, а не 1000.0K
            return f"{n / size:.1f}{unit}"
    return str(int(n))


def money(x):
    return f"${x:,.2f}"


def fmt_dt(t):
    return datetime.fromtimestamp(t).strftime("%Y-%m-%d %H:%M")


ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[0-9A-Za-z]")


def clean_text(s):
    """Заголовки чатов — произвольный пользовательский текст: там встречаются
    сырые ANSI-коды, эмодзи и CJK. Широкие символы ломают колоночную вёрстку
    (curses считает ширину по колонкам, python — по кодпоинтам), а старый
    ncurses на краю экрана режет их в «?» — заменяем на «·», контролы режем."""
    s = ANSI_RE.sub("", s)
    out = []
    for ch in s:
        if ch == "�" or unicodedata.category(ch)[0] == "C":
            out.append(" ")            # ZWSP и прочие: пробел, чтобы слова не слипались
            continue
        if ord(ch) > 0xFFFF or unicodedata.east_asian_width(ch) in ("W", "F"):
            out.append("·")
            continue
        out.append(ch)
    return "".join(out)


# ---------------------------------------------------------------- сбор данных

class Rec:
    __slots__ = ("t", "model", "session", "project",
                 "tin", "tout", "cw", "cr", "cw1h",
                 "cost", "day", "hour", "wd", "tools")


class Collector:
    """Инкрементальный парсер JSONL: помнит, до какого байта дочитан каждый
    файл, и на повторном scan() разбирает только дописанное — это и делает
    возможным live-режим. Дедупликация по message.id (пофилдовый максимум)."""

    def __init__(self):
        self.by_mid = {}
        self.records = []
        self.titles = {}
        self.unknown = set()
        self.pos = {}            # путь -> байт, до которого файл разобран
        self.seen_tools = set()  # id tool_use-блоков (дедуп вызовов)
        self.dirty = set()       # записи, которым нужно пересчитать cost

    def scan(self):
        """Дочитывает новые/изменённые файлы. True — данные изменились."""
        changed = False
        for fp in glob.glob(os.path.join(ROOT, "**", "*.jsonl"), recursive=True):
            try:
                size = os.path.getsize(fp)
            except OSError:
                continue
            done = self.pos.get(fp, 0)
            if size == done:
                continue
            if size < done:
                done = 0             # файл переписан — читаем заново (дедуп спасает)
            try:
                fh = open(fp, "rb")
            except OSError:
                continue
            with fh:
                fh.seek(done)
                data = fh.read()
            end = data.rfind(b"\n") + 1
            if end == 0:
                continue             # недописанная строка — дождёмся следующего тика
            self.pos[fp] = done + end
            for raw in data[:end].split(b"\n"):
                if raw and self._line(raw.decode("utf-8", "replace")):
                    changed = True
        if self.dirty:
            for r in self.dirty:
                c = cost_of(r.model, r.tin, r.tout, r.cw, r.cr, r.cw1h)
                if c is None:
                    self.unknown.add(r.model)
                    c = 0.0
                r.cost = c
            self.dirty.clear()
            changed = True
        return changed

    def _line(self, line):
        if '"usage"' not in line and '"type":"user"' not in line \
                and '"type": "user"' not in line:
            return False
        try:
            o = json.loads(line)
        except ValueError:
            return False
        typ = o.get("type")
        if typ == "user":
            self._maybe_title(o)
            return False
        if typ != "assistant":
            return False
        m = o.get("message", {})
        u = m.get("usage")
        if not u:
            return False
        tin = u.get("input_tokens", 0)
        tout = u.get("output_tokens", 0)
        cw = u.get("cache_creation_input_tokens", 0)
        cr = u.get("cache_read_input_tokens", 0)
        if tin + tout + cw + cr == 0:
            return False               # синтетические/пустые сообщения
        cc = u.get("cache_creation") or {}
        cw1h = cc.get("ephemeral_1h_input_tokens", 0)
        mid = m.get("id") or object()  # нет id — не дедуплицируем
        r = self.by_mid.get(mid)
        touched = False
        if r is None:
            r = Rec()
            r.model = m.get("model", "unknown")
            r.session = o.get("sessionId", "?")
            cwd = o.get("cwd") or ""
            r.project = os.path.basename(cwd) or "?"
            r.tin, r.tout, r.cw, r.cr, r.cw1h = tin, tout, cw, cr, cw1h
            r.t = 0.0
            r.day, r.hour, r.wd = "?", -1, -1
            r.tools = ()
            self.by_mid[mid] = r
            self.records.append(r)
            touched = True
        else:
            # стриминг: строки одного сообщения с растущим usage
            for f, v in (("tin", tin), ("tout", tout), ("cw", cw),
                         ("cr", cr), ("cw1h", cw1h)):
                if v > getattr(r, f):
                    setattr(r, f, v)
                    touched = True
        if not r.t:
            t = parse_ts(o.get("timestamp"))
            if t:
                r.t = t
                lt = datetime.fromtimestamp(t)
                r.day = lt.strftime("%Y-%m-%d")
                r.hour = lt.hour
                r.wd = lt.weekday()
        names = self._tool_uses(m.get("content"))
        if names:
            r.tools = r.tools + tuple(names)
            touched = True
        if touched:
            self.dirty.add(r)
        return touched

    def _tool_uses(self, content):
        if not isinstance(content, list):
            return []
        names = []
        for b in content:
            if not (isinstance(b, dict) and b.get("type") == "tool_use"):
                continue
            bid = b.get("id")
            if bid:
                if bid in self.seen_tools:
                    continue           # дубль из resume/fork
                self.seen_tools.add(bid)
            names.append(b.get("name") or "?")
        return names

    def _maybe_title(self, o):
        if o.get("isSidechain"):
            return
        sid = o.get("sessionId")
        if not sid or sid in self.titles:
            return
        c = o.get("message", {}).get("content")
        text = None
        if isinstance(c, str):
            text = c
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and b.get("type") == "text":
                    text = b.get("text")
                    break
        if not text:
            return
        text = " ".join(clean_text(text).split())
        if text and not text.startswith("<") and not text.startswith("Caveat"):
            self.titles[sid] = text[:80]


# ---------------------------------------------------------------- агрегация

def tok(a):
    return a["tin"] + a["tout"] + a["cw"] + a["cr"]


def aggregate(records, keyfn):
    d = {}
    for r in records:
        k = keyfn(r)
        a = d.get(k)
        if a is None:
            a = d[k] = {"tin": 0, "tout": 0, "cw": 0, "cr": 0,
                        "cost": 0.0, "msgs": 0, "mc": defaultdict(int)}
        a["tin"] += r.tin
        a["tout"] += r.tout
        a["cw"] += r.cw
        a["cr"] += r.cr
        a["cost"] += r.cost
        a["msgs"] += 1
        a["mc"][r.model] += r.tin + r.tout + r.cw + r.cr
    return d


def tools_agg(records):
    """Счётчик вызовов инструментов; стоимость сообщения делится поровну
    между его вызовами (приблизительная атрибуция)."""
    d = {}
    for r in records:
        if not r.tools:
            continue
        n = len(r.tools)
        for name, c in Counter(r.tools).items():
            a = d.setdefault(name, {"calls": 0, "msgs": 0, "cost": 0.0})
            a["calls"] += c
            a["msgs"] += 1
            a["cost"] += r.cost * c / n
    return d


def top_model(a):
    return max(a["mc"].items(), key=lambda kv: kv[1])[0] if a["mc"] else "?"


def cache_saved(records):
    """Сколько сэкономил кэш против мира без кэша (чтения по полной цене,
    но и без наценок за запись)."""
    saved = 0.0
    for r in records:
        p = price_for(r.model)
        if not p:
            continue
        ci = p[0] / 1e6
        cw5 = max(r.cw - r.cw1h, 0)
        saved += (r.cr * ci * (1 - CACHE_READ)
                  - cw5 * ci * (CACHE_W_5M - 1)
                  - r.cw1h * ci * (CACHE_W_1H - 1))
    return saved


def streak_of(days):
    d = date.today()
    if d.isoformat() not in days:
        d -= timedelta(days=1)
    n = 0
    while d.isoformat() in days:
        n += 1
        d -= timedelta(days=1)
    return n


def overview(records):
    if not records:
        return None
    now = time.time()
    total_cost = sum(r.cost for r in records)
    total_tok = sum(r.tin + r.tout + r.cw + r.cr for r in records)
    tin = sum(r.tin for r in records)
    tout = sum(r.tout for r in records)
    cw = sum(r.cw for r in records)
    cr = sum(r.cr for r in records)
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    busiest = max(days.items(), key=lambda kv: kv[1]["cost"]) if days else ("?", {"cost": 0})
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    peak_h = max(hours.items(), key=lambda kv: kv[1]["cost"]) if hours else (-1, {"cost": 0})
    models = aggregate(records, lambda r: r.model)
    top_m = max(models.items(), key=lambda kv: kv[1]["cost"]) if models else ("?", {"cost": 0})
    dd = sorted(days) if days else []
    t = datetime.now()
    today = t.strftime("%Y-%m-%d")
    m0 = datetime(t.year, t.month, 1).timestamp()
    mtd = sum(r.cost for r in records if r.t >= m0)
    dim = calendar.monthrange(t.year, t.month)[1]
    return {
        "cost": total_cost, "tok": total_tok,
        "tin": tin, "tout": tout, "cw": cw, "cr": cr,
        "msgs": len(records),
        "sessions": len({r.session for r in records}),
        "ndays": len(days),
        "first": dd[0] if dd else "?", "last": dd[-1] if dd else "?",
        "busiest_day": busiest, "peak_hour": peak_h,
        "top_model": top_m,
        "avg_day": total_cost / len(days) if days else 0,
        "today": days[today]["cost"] if today in days else 0.0,
        "hour_cost": sum(r.cost for r in records if r.t >= now - 3600),
        "saved": cache_saved(records),
        "mtd": mtd,
        "forecast": mtd / t.day * dim,
        "streak": streak_of(days),
        "cache_share": (cr / total_tok * 100) if total_tok else 0,
        "days": days,
    }


def fill_days(days):
    """Непрерывный ряд (день, $) от первого до последнего дня — с нулями
    в дни без активности, чтобы ось времени спарклайна не врала."""
    if not days:
        return []
    ds = sorted(days)
    try:
        d0, d1 = date.fromisoformat(ds[0]), date.fromisoformat(ds[-1])
    except ValueError:
        return [(k, days[k]["cost"]) for k in ds]
    if (d1 - d0).days > 730:                  # защита от мусорных таймстампов
        return [(k, days[k]["cost"]) for k in ds]
    out = []
    d = d0
    while d <= d1:
        k = d.isoformat()
        a = days.get(k)
        out.append((k, a["cost"] if a else 0.0))
        d += timedelta(days=1)
    return out


# ---------------------------------------------------------------- периоды

PERIODS = ["всё", "сегодня", "7 дней", "30 дней", "месяц"]


def cutoff(idx):
    if idx == 0:
        return None
    now = time.time()
    t = datetime.now()
    if idx == 1:
        return datetime(t.year, t.month, t.day).timestamp()
    if idx == 2:
        return now - 7 * 86400
    if idx == 3:
        return now - 30 * 86400
    if idx == 4:
        return datetime(t.year, t.month, 1).timestamp()
    return None


def apply_period(records, idx):
    c = cutoff(idx)
    if c is None:
        return records
    return [r for r in records if r.t >= c]


# ---------------------------------------------------------------- графики

FULL = "█"
EIGHTHS = "▏▎▍▌▋▊▉█"
SPARK = " ▁▂▃▄▅▆▇█"
SEP = "─"
BOX = "┌┐└┘─│"


def set_ascii_glyphs():
    """Фолбэк, когда UTF-8 недоступен: рисуем графику на ASCII, а не на ?."""
    global FULL, EIGHTHS, SPARK, SEP, BOX
    FULL = "#"
    EIGHTHS = " .:-=+*#"
    SPARK = " .:-=+*#@"
    SEP = "-"
    BOX = "++++-|"


def bar(frac, width):
    if width <= 0 or frac <= 0:
        return ""
    fb = frac * width
    n = int(fb)
    s = FULL * min(n, width)
    if n < width:
        rem = fb - n
        if rem > 0:
            s += EIGHTHS[min(int(rem * 8), 7)]
    return s


def sparkline(values, width):
    vals = values[-width:] if len(values) > width else values
    if not vals:
        return ""
    mx = max(vals) or 1
    return "".join(SPARK[min(int(v / mx * 8), 8)] for v in vals)


def spark_level(v, mx):
    if v <= 0:
        return 0
    return max(1, min(int(v / mx * 8), 8))


# ---------------------------------------------------------------- текстовый режим

def print_text(co):
    records, titles, unknown = co.records, co.titles, co.unknown
    ov = overview(records)
    if not ov:
        print("нет данных")
        return
    print()
    print(f"  ВСЕГО   {ov['tok']:,} токенов   ≈ {money(ov['cost'])} (по прайсу API)")
    print(f"          {ov['msgs']:,} сообщений · {ov['sessions']} чатов · "
          f"{ov['ndays']} дней ({ov['first']} … {ov['last']}) · "
          f"стрик {ov['streak']} дн.")
    bd, bh = ov["busiest_day"], ov["peak_hour"]
    peak = f"{bh[0]:02d}:00" if bh[0] >= 0 else "—"
    print(f"          пик дня: {bd[0]} ({money(bd[1]['cost'])}) · "
          f"пик часа: {peak} · ${ov['avg_day']:.2f}/день · "
          f"сегодня {money(ov['today'])} · кэш-чтения {ov['cache_share']:.1f}% токенов")
    print(f"          кэш сэкономил ≈ {money(ov['saved'])} "
          f"(без кэша ≈ {money(ov['cost'] + ov['saved'])}) · "
          f"прогноз на месяц {money(ov['forecast'])}")
    if unknown:
        print(f"          нет прайса (стоимость = $0): {', '.join(sorted(unknown))}")

    def table(title, agg, namefn, sortkey="cost", limit=15, showmodel=False):
        rows = sorted(agg.items(), key=lambda kv: -kv[1][sortkey])[:limit]
        if not rows:
            return
        mx = max(tok(a) for _, a in rows) or 1
        print(f"\n  {title}")
        print("  " + "-" * 72)
        for k, a in rows:
            name = namefn(k, a)[:30]
            b = bar(tok(a) / mx, 14)
            mdl = f" {top_model(a).replace('claude-', ''):11}" if showmodel else ""
            print(f"  {name:30}{mdl} {b:14} {h(tok(a)):>7} {money(a['cost']):>11}")

    table("МОДЕЛИ", aggregate(records, lambda r: r.model),
          lambda k, a: k.replace("claude-", ""))
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    table("ДНИ (топ по $)", days, lambda k, a: k)
    chats = aggregate(records, lambda r: r.session)
    table("ЧАТЫ", chats,
          lambda k, a: titles.get(k, "(" + k[:8] + ")"), showmodel=True)
    table("ПРОЕКТЫ", aggregate(records, lambda r: r.project), lambda k, a: k)
    tools = tools_agg(records)
    if tools:
        rows = sorted(tools.items(), key=lambda kv: -kv[1]["calls"])[:15]
        mx = rows[0][1]["calls"] or 1
        print("\n  ИНСТРУМЕНТЫ (по вызовам)")
        print("  " + "-" * 72)
        for k, a in rows:
            print(f"  {k[:30]:30} {bar(a['calls'] / mx, 14):14} "
                  f"{a['calls']:>7,} {money(a['cost']):>11}")
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    print("\n  ЧАСЫ (по $, локальное время)")
    print("  " + "-" * 72)
    mxh = max((a["cost"] for a in hours.values()), default=1) or 1
    for hh in range(24):
        a = hours.get(hh)
        c = a["cost"] if a else 0
        print(f"  {hh:02d}:00  {bar(c / mxh, 40):40} {money(c):>10}")
    print()


def print_json(co):
    records, titles, unknown = co.records, co.titles, co.unknown
    ov = overview(records)

    def pack(agg, namefn=None, sort=True):
        items = agg.items()
        if sort:
            items = sorted(items, key=lambda kv: -kv[1]["cost"])
        out = []
        for k, a in items:
            d = {"key": str(k), "cost": round(a["cost"], 4), "tokens": tok(a),
                 "input": a["tin"], "output": a["tout"],
                 "cache_write": a["cw"], "cache_read": a["cr"], "msgs": a["msgs"]}
            if namefn:
                d["title"] = namefn(k)
            out.append(d)
        return out

    if not ov:
        json.dump({"total": None}, sys.stdout)
        print()
        return
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    data = {
        "total": {
            "cost": round(ov["cost"], 4), "tokens": ov["tok"],
            "input": ov["tin"], "output": ov["tout"],
            "cache_write": ov["cw"], "cache_read": ov["cr"],
            "msgs": ov["msgs"], "sessions": ov["sessions"],
            "days": ov["ndays"], "first": ov["first"], "last": ov["last"],
            "cache_saved": round(ov["saved"], 4),
            "forecast_month": round(ov["forecast"], 4),
            "streak_days": ov["streak"],
        },
        "unknown_models": sorted(unknown),
        "models": pack(aggregate(records, lambda r: r.model)),
        "days": pack(days, sort=False),
        "chats": pack(aggregate(records, lambda r: r.session),
                      namefn=lambda k: titles.get(k, "")),
        "projects": pack(aggregate(records, lambda r: r.project)),
        "tools": [
            {"key": k, "calls": a["calls"], "msgs": a["msgs"],
             "cost": round(a["cost"], 4)}
            for k, a in sorted(tools_agg(records).items(),
                               key=lambda kv: -kv[1]["calls"])
        ],
        "hours": pack(aggregate([r for r in records if r.hour >= 0],
                                lambda r: r.hour), sort=False),
    }
    json.dump(data, sys.stdout, ensure_ascii=False, indent=2)
    print()


# ---------------------------------------------------------------- TUI (curses)

TABS = ["Обзор", "Модели", "Дни", "Чаты", "Проекты", "Тулзы", "Часы", "Неделя"]
WDAYS = ["пн", "вт", "ср", "чт", "пт", "сб", "вс"]
TABLE_TABS = (1, 2, 3, 4, 5)


class App:
    def __init__(self, collector):
        self.co = collector
        self.tab = 0
        self.period = 0
        self.sortkey = "cost"          # cost | tok
        self.sel = [0] * len(TABS)
        self.detail = None             # (tab, key) — открытая карточка
        self.live = True               # автообновление каждые ~2 c
        self._off = 0                  # прокрутка текущей таблицы (для мыши)
        self._tab_spans = []           # x-диапазоны вкладок (для мыши)
        self.recompute()

    def recompute(self):
        self.f = apply_period(self.co.records, self.period)
        self.ov = overview(self.f)
        self.ag_models = aggregate(self.f, lambda r: r.model)
        days = aggregate(self.f, lambda r: r.day)
        days.pop("?", None)
        self.ag_days = days
        self.ag_chats = aggregate(self.f, lambda r: r.session)
        self.ag_proj = aggregate(self.f, lambda r: r.project)
        self.ag_tools = tools_agg(self.f)
        self.ag_hours = aggregate([r for r in self.f if r.hour >= 0], lambda r: r.hour)
        heat = defaultdict(float)
        for r in self.f:
            if r.hour >= 0 and r.wd >= 0:
                heat[(r.wd, r.hour)] += r.cost
        self.ag_heat = dict(heat)

    def sorted_rows(self, agg):
        if self.sortkey == "tok":
            return sorted(agg.items(), key=lambda kv: -tok(kv[1]))
        return sorted(agg.items(), key=lambda kv: -kv[1]["cost"])

    def rows_for(self, tab):
        if tab == 1:
            return self.sorted_rows(self.ag_models)
        if tab == 2:
            return sorted(self.ag_days.items())          # по дате
        if tab == 3:
            return self.sorted_rows(self.ag_chats)
        if tab == 4:
            return self.sorted_rows(self.ag_proj)
        if tab == 5:
            key = (lambda kv: -kv[1]["calls"]) if self.sortkey == "tok" \
                else (lambda kv: -kv[1]["cost"])
            return sorted(self.ag_tools.items(), key=key)
        if tab == 6:
            return [(hh, self.ag_hours.get(hh)) for hh in range(24)]
        return []

    # ------------------------------------------------------------ цикл
    def run(self, scr):
        curses.curs_set(0)
        scr.timeout(2000)              # тик live-режима
        try:
            curses.mousemask(curses.ALL_MOUSE_EVENTS)
        except (curses.error, AttributeError):   # PDCurses может не уметь
            pass
        self._init_colors()
        while True:
            self.draw(scr)
            while True:
                ch = scr.getch()
                if ch != -1:
                    break
                if self.live and self.co.scan():
                    self.recompute()
                    ch = -1
                    break
            if ch == -1:               # live-тик с новыми данными
                continue
            if ch == ord("r"):
                self.reload(scr)
                continue
            if ch == ord("p"):
                self.live = not self.live
                continue
            if not self.handle(ch):
                break

    def reload(self, scr):
        maxy, maxx = scr.getmaxyx()
        self.add(scr, maxy - 1, 1, "перечитываю всё с нуля…".ljust(maxx - 2),
                 self.c["head"])
        scr.refresh()
        self.co = Collector()
        self.co.scan()
        self.recompute()

    def _init_colors(self):
        # Роли: dim (второстепенный текст), head (заголовки), money ($),
        # bar (графики), tab (активная вкладка). Значение каждой роли — готовый
        # curses-атрибут, который можно | с A_REVERSE и т.п.
        self.c = defaultdict(int)
        no_color = os.environ.get("NO_COLOR") is not None
        if no_color or not curses.has_colors():
            # без цвета — держим структуру на атрибутах
            self.c["dim"] = curses.A_DIM
            self.c["head"] = curses.A_BOLD
            self.c["money"] = curses.A_BOLD
            self.c["bar"] = 0
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD
            return
        curses.start_color()
        try:
            curses.use_default_colors()   # фон = родной фон терминала
            bg = -1
        except (curses.error, AttributeError):
            bg = curses.COLOR_BLACK
        ncolors = getattr(curses, "COLORS", 8)
        if ncolors >= 256:
            # аккуратные оттенки, читаемые и на тёмном, и на светлом фоне
            specs = [
                ("dim",   245, bg, 0),                 # серый, а не синий
                ("head",  179, bg, curses.A_BOLD),     # тёпло-жёлтый
                ("money", 71,  bg, 0),                 # зелёный
                ("bar",   37,  bg, 0),                 # бирюзовый
                ("tab",   16,  37, curses.A_BOLD),     # тёмный на бирюзе
                ("sel",   231, 24, curses.A_BOLD),     # выделение: белый на синем
            ]
        else:
            # 8/16 цветов: серого нет — берём белый + A_DIM
            specs = [
                ("dim",   curses.COLOR_WHITE,  bg, curses.A_DIM),
                ("head",  curses.COLOR_YELLOW, bg, curses.A_BOLD),
                ("money", curses.COLOR_GREEN,  bg, 0),
                ("bar",   curses.COLOR_CYAN,   bg, 0),
                ("tab",   curses.COLOR_BLACK,  curses.COLOR_CYAN, curses.A_BOLD),
                ("sel",   curses.COLOR_WHITE,  curses.COLOR_BLUE, curses.A_BOLD),
            ]
        for i, (name, fg, b, extra) in enumerate(specs, start=1):
            try:
                curses.init_pair(i, fg, b)
                self.c[name] = curses.color_pair(i) | extra
            except curses.error:
                self.c[name] = extra
        # если пары не создались — держим читаемость через инверсию
        if not self.c["tab"]:
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
        if not self.c["sel"]:
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD

    def handle(self, ch):
        if self.detail is not None:
            if ch == curses.KEY_MOUSE:
                try:
                    _, _, _, _, bs = curses.getmouse()
                except curses.error:
                    return True
                if bs & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED
                         | curses.BUTTON1_DOUBLE_CLICKED):
                    self.detail = None
                return True
            if ch in (27, ord("q"), curses.KEY_ENTER, 10, 13):
                self.detail = None
            return True
        if ch in (ord("q"), 27):
            return False
        n = len(TABS)
        if ch == curses.KEY_MOUSE:
            self._mouse()
        elif ch in (curses.KEY_RIGHT, ord("l"), ord("]"), ord("\t")):
            self.tab = (self.tab + 1) % n
        elif ch in (curses.KEY_LEFT, ord("h"), ord("[")):
            self.tab = (self.tab - 1) % n
        elif ord("1") <= ch < ord("1") + n:
            self.tab = ch - ord("1")
        elif ch in (curses.KEY_DOWN, ord("j")):
            self.sel[self.tab] += 1
        elif ch in (curses.KEY_UP, ord("k")):
            self.sel[self.tab] = max(0, self.sel[self.tab] - 1)
        elif ch == curses.KEY_NPAGE:
            self.sel[self.tab] += 10
        elif ch == curses.KEY_PPAGE:
            self.sel[self.tab] = max(0, self.sel[self.tab] - 10)
        elif ch in (curses.KEY_HOME, ord("g")):
            self.sel[self.tab] = 0
        elif ch in (curses.KEY_END, ord("G")):
            self.sel[self.tab] = 10 ** 9      # прижмётся в draw_table
        elif ch in (curses.KEY_ENTER, 10, 13) and self.tab in TABLE_TABS:
            rows = self.rows_for(self.tab)
            if rows:
                sel = min(self.sel[self.tab], len(rows) - 1)
                self.detail = (self.tab, rows[sel][0])
        elif ch == ord("f"):
            self.period = (self.period + 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("F"):
            self.period = (self.period - 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("s"):
            self.sortkey = "tok" if self.sortkey == "cost" else "cost"
        return True

    def _mouse(self):
        try:
            _, mx, my, _, bs = curses.getmouse()
        except curses.error:
            return
        b5 = getattr(curses, "BUTTON5_PRESSED", 0x200000)
        if bs & curses.BUTTON4_PRESSED:                       # колесо вверх
            self.sel[self.tab] = max(0, self.sel[self.tab] - 3)
            return
        if bs & b5:                                           # колесо вниз
            self.sel[self.tab] += 3
            return
        if not bs & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED
                     | curses.BUTTON1_DOUBLE_CLICKED):
            return
        if my == 1:                                           # клик по вкладке
            for i, (x0, x1) in enumerate(self._tab_spans):
                if x0 <= mx < x1:
                    self.tab = i
                    return
            return
        if my >= 4 and self.tab in TABLE_TABS:                # клик по строке
            rows = self.rows_for(self.tab)
            idx = self._off + (my - 4)
            if 0 <= idx < len(rows):
                if idx == self.sel[self.tab] \
                        or bs & curses.BUTTON1_DOUBLE_CLICKED:
                    self.sel[self.tab] = idx
                    self.detail = (self.tab, rows[idx][0])    # второй клик = карточка
                else:
                    self.sel[self.tab] = idx

    def add(self, scr, y, x, s, attr=0):
        maxy, maxx = scr.getmaxyx()
        if y < 0 or y >= maxy or x < 0 or x >= maxx:
            return
        s = s[: maxx - x - 1]
        try:
            scr.addstr(y, x, s, attr)
        except (curses.error, UnicodeEncodeError):
            pass                           # край экрана / не-юникодная консоль

    def draw(self, scr):
        scr.erase()
        maxy, maxx = scr.getmaxyx()
        head = self.ov
        cost = money(head["cost"]) if head else "$0.00"
        toks = h(head["tok"]) if head else "0"
        self.add(scr, 0, 1, "ccost", curses.A_BOLD)
        if self.live:
            self.add(scr, 0, 7, "live", self.c["money"])
        else:
            self.add(scr, 0, 7, "пауза", self.c["dim"] | curses.A_REVERSE)
        right = f"{toks} токенов · {cost} · период: {PERIODS[self.period]}"
        self.add(scr, 0, max(14, maxx - len(right) - 2), right, self.c["dim"])
        # вкладки
        x = 1
        self._tab_spans = []
        for i, name in enumerate(TABS):
            label = f" {i+1}·{name} "
            self._tab_spans.append((x, x + len(label)))
            attr = self.c["tab"] | curses.A_BOLD if i == self.tab else curses.A_DIM
            self.add(scr, 1, x, label, attr)
            x += len(label)
        self.add(scr, 2, 1, SEP * (maxx - 2), self.c["dim"])
        body_top = 3
        body_h = maxy - body_top - 1
        if not head:
            self.add(scr, body_top + 1, 2,
                     "нет данных за период «%s»" % PERIODS[self.period])
        elif self.tab == 0:
            self.draw_overview(scr, body_top, body_h, maxx)
        elif self.tab == 5:
            self.draw_tools(scr, body_top, body_h, maxx)
        elif self.tab == 6:
            self.draw_hours(scr, body_top, body_h, maxx)
        elif self.tab == 7:
            self.draw_heat(scr, body_top, body_h, maxx)
        else:
            self.draw_table(scr, body_top, body_h, maxx)
        if self.detail is not None:
            self.draw_detail(scr, maxy, maxx)
            foot = "Esc/Enter/клик — закрыть карточку"
        else:
            foot = ("1-8 · ↑↓ · Enter карточка · f период · s сорт(%s) · "
                    "p live · r перечитать · q выход" % self.sortkey)
        self.add(scr, maxy - 1, 1, foot, self.c["dim"])
        scr.refresh()

    def draw_overview(self, scr, top, h_, maxx):
        o = self.ov
        y = top + 1
        self.add(scr, y, 2, money(o["cost"]), self.c["money"] | curses.A_BOLD)
        self.add(scr, y, 16, f"{o['tok']:,} токенов", curses.A_BOLD)
        y += 2
        peak = f"{o['peak_hour'][0]:02d}:00" if o["peak_hour"][0] >= 0 else "—"
        lines = [
            ("сообщений", f"{o['msgs']:,}"),
            ("чатов", f"{o['sessions']:,}"),
            ("активных дней", f"{o['ndays']}  ({o['first']} … {o['last']}) · "
                              f"стрик {o['streak']} дн."),
            ("в среднем / день", money(o["avg_day"])),
            ("сегодня", f"{money(o['today'])} · за час {money(o['hour_cost'])}"),
            ("прогноз на месяц", f"{money(o['forecast'])} (факт {money(o['mtd'])})"),
            ("пик дня", f"{o['busiest_day'][0]}  ({money(o['busiest_day'][1]['cost'])})"),
            ("пик часа", peak),
            ("топ-модель", o["top_model"][0].replace("claude-", "")),
            ("кэш-чтения", f"{o['cache_share']:.1f}% всех токенов"),
            ("кэш сэкономил", f"≈ {money(o['saved'])} "
                              f"(без кэша ≈ {money(o['cost'] + o['saved'])})"),
        ]
        for name, val in lines:
            self.add(scr, y, 2, f"{name:>18} :", self.c["dim"])
            self.add(scr, y, 23, val)
            y += 1
        y += 1
        self.add(scr, y, 2, "токены:", self.c["head"])
        self.add(scr, y, 12,
                 f"input {h(o['tin'])} · cache-wr {h(o['cw'])} · "
                 f"cache-rd {h(o['cr'])} · output {h(o['tout'])}")
        y += 1
        if self.co.unknown:
            self.add(scr, y, 2,
                     "нет прайса (стоимость = $0): "
                     + ", ".join(sorted(self.co.unknown)),
                     self.c["head"])
            y += 1
        y += 1
        self.add(scr, y, 2, "стоимость по дням:", self.c["head"])
        y += 1
        seq = fill_days(self.ag_days)
        if seq:
            width = min(maxx - 6, 80)
            shown = seq[-width:]
            vals = [c for _, c in shown]
            self.add(scr, y, 2, sparkline(vals, width), self.c["bar"])
            y += 1
            self.add(scr, y, 2,
                     f"{shown[0][0]}  →  {shown[-1][0]}   макс ${max(vals):.2f}/день",
                     self.c["dim"])

    def draw_table(self, scr, top, h_, maxx):
        rows = self.rows_for(self.tab)
        sel = self.sel[self.tab] = min(self.sel[self.tab], max(0, len(rows) - 1))
        off = self._off = window(sel, len(rows), h_ - 1)
        mx = max((tok(a) for _, a in rows), default=1) or 1
        title = {1: "модель", 2: "день", 3: "чат", 4: "проект"}[self.tab]
        self.add(scr, top, 2, title, self.c["head"])
        self.add(scr, top, maxx - 37, f"{'input':>6}{'cache':>7}{'out':>7}",
                 self.c["head"] | curses.A_DIM)
        self.add(scr, top, maxx - 12, "$", self.c["head"])
        namew = max(12, maxx - 55)
        bx = 2 + namew + 1
        bw = max(0, min(12, maxx - 38 - bx))   # не наезжать на числа в узком окне
        for i in range(off, min(len(rows), off + h_ - 1)):
            k, a = rows[i]
            y = top + 1 + (i - off)
            selected = i == sel
            if selected:                         # сплошная подсветка на всю ширину
                self.add(scr, y, 1, " " * (maxx - 2), self.c["sel"])
            a_txt = self.c["sel"] if selected else 0
            a_bar = self.c["sel"] if selected else self.c["bar"]
            a_dim = self.c["sel"] if selected else self.c["dim"]
            a_mon = self.c["sel"] if selected else self.c["money"]
            if self.tab == 1:
                name = k.replace("claude-", "")
            elif self.tab == 3:
                name = self.co.titles.get(k) or f"({k[:8]})"
            else:
                name = k
            mark = "> " if selected else "  "
            self.add(scr, y, 1, f"{mark}{name}"[:namew + 1].ljust(namew + 1), a_txt)
            self.add(scr, y, bx, bar(tok(a) / mx, bw), a_bar)
            self.add(scr, y, maxx - 37,
                     f"{h(a['tin']):>6}{h(a['cw'] + a['cr']):>7}{h(a['tout']):>7}", a_dim)
            self.add(scr, y, maxx - 13, f"{money(a['cost']):>11}", a_mon)
        if len(rows) > h_ - 1:
            self.add(scr, top, maxx - 46, f"[{sel + 1}/{len(rows)}]", self.c["dim"])

    def draw_tools(self, scr, top, h_, maxx):
        rows = self.rows_for(5)
        if not rows:
            self.add(scr, top + 1, 2, "вызовов инструментов не найдено")
            return
        sel = self.sel[5] = min(self.sel[5], len(rows) - 1)
        off = self._off = window(sel, len(rows), h_ - 1)
        mx = max(a["calls"] for _, a in rows) or 1
        self.add(scr, top, 2, "инструмент", self.c["head"])
        self.add(scr, top, maxx - 41, f"{'вызовы':>8}{'сообщ.':>9}",
                 self.c["head"] | curses.A_DIM)
        self.add(scr, top, maxx - 13, "$≈", self.c["head"])
        namew = max(12, maxx - 59)
        bx = 2 + namew + 1
        bw = max(0, min(12, maxx - 42 - bx))
        for i in range(off, min(len(rows), off + h_ - 1)):
            k, a = rows[i]
            y = top + 1 + (i - off)
            selected = i == sel
            if selected:
                self.add(scr, y, 1, " " * (maxx - 2), self.c["sel"])
            a_txt = self.c["sel"] if selected else 0
            a_bar = self.c["sel"] if selected else self.c["bar"]
            a_dim = self.c["sel"] if selected else self.c["dim"]
            a_mon = self.c["sel"] if selected else self.c["money"]
            mark = "> " if selected else "  "
            self.add(scr, y, 1, f"{mark}{k}"[:namew + 1].ljust(namew + 1), a_txt)
            self.add(scr, y, bx, bar(a["calls"] / mx, bw), a_bar)
            self.add(scr, y, maxx - 41, f"{a['calls']:>8,}{a['msgs']:>9,}", a_dim)
            self.add(scr, y, maxx - 13, f"{money(a['cost']):>11}", a_mon)
        if len(rows) > h_ - 1:
            self.add(scr, top, maxx - 51, f"[{sel + 1}/{len(rows)}]", self.c["dim"])

    def draw_hours(self, scr, top, h_, maxx):
        self.add(scr, top, 2, "активность по часам (локальное время)", self.c["head"])
        mxc = max((a["cost"] for a in self.ag_hours.values()), default=1) or 1
        bw = max(10, maxx - 30)
        for hh in range(24):
            y = top + 1 + hh
            if y >= top + h_:
                break
            a = self.ag_hours.get(hh)
            c = a["cost"] if a else 0
            msgs = a["msgs"] if a else 0
            self.add(scr, y, 2, f"{hh:02d}:00", self.c["dim"])
            self.add(scr, y, 8, bar(c / mxc, bw), self.c["bar"])
            self.add(scr, y, maxx - 20, f"{msgs:>5} msg {money(c):>9}", self.c["money"])

    def draw_heat(self, scr, top, h_, maxx):
        self.add(scr, top, 2, "стоимость по дням недели и часам (локальное время)",
                 self.c["head"])
        heat = self.ag_heat
        mx = max(heat.values(), default=0) or 1
        x0 = 6
        ruler = "".join(f"{hh:02d}" + " " * 6 for hh in (0, 4, 8, 12, 16, 20))
        self.add(scr, top + 2, x0, ruler[:48], self.c["dim"])
        for wd in range(7):
            y = top + 3 + wd
            if y >= top + h_:
                return
            row_cost = 0.0
            cells = []
            for hh in range(24):
                v = heat.get((wd, hh), 0.0)
                row_cost += v
                cells.append(SPARK[spark_level(v, mx)] * 2)
            self.add(scr, y, 2, WDAYS[wd], self.c["dim"])
            self.add(scr, y, x0, "".join(cells), self.c["bar"])
            if row_cost:
                self.add(scr, y, x0 + 50, f"{money(row_cost):>10}", self.c["money"])
        y = top + 11
        if y < top + h_:
            self.add(scr, y, 2,
                     f"ячейка = час недели · {FULL} = {money(mx)} (макс за час)",
                     self.c["dim"])

    # ------------------------------------------------------------ карточка
    def _detail_records(self, tab, key):
        if tab == 5:
            return [r for r in self.f if key in r.tools]
        fld = {1: "model", 2: "day", 3: "session", 4: "project"}[tab]
        return [r for r in self.f if getattr(r, fld) == key]

    def draw_detail(self, scr, maxy, maxx):
        tab, key = self.detail
        sub = self._detail_records(tab, key)
        if not sub:
            self.detail = None
            return
        kind = {1: "модель", 2: "день", 3: "чат", 4: "проект", 5: "инструмент"}[tab]
        if tab == 1:
            name = key.replace("claude-", "")
        elif tab == 3:
            name = self.co.titles.get(key) or "(без названия)"
        else:
            name = key
        total = sum(r.cost for r in sub)
        tin = sum(r.tin for r in sub)
        tout = sum(r.tout for r in sub)
        cw = sum(r.cw for r in sub)
        cr = sum(r.cr for r in sub)
        ts = [r.t for r in sub if r.t]
        days = {r.day for r in sub if r.day != "?"}

        w = min(maxx - 4, 74)
        inner = w - 4
        lines = []                      # (текст, роль)
        for part in textwrap.wrap(name, inner)[:2] or [name[:inner]]:
            lines.append((part, "head"))
        if tab == 3:
            lines.append((f"id {str(key)[:8]} · проект {sub[0].project}", "dim"))
        else:
            ns = len({r.session for r in sub})
            lines.append((f"чатов: {ns}", "dim"))
        lines.append(("", ""))
        if tab == 5:
            calls = sum(r.tools.count(key) for r in sub)
            lines.append((f"{calls:,} вызовов · {len(sub):,} сообщений · "
                          f"{money(total)} в этих сообщениях", "money"))
        else:
            lines.append((f"{money(total)} · {len(sub):,} сообщений · "
                          f"{money(total / len(sub))}/сообщение", "money"))
        if ts:
            t0, t1 = min(ts), max(ts)
            if tab == 3:
                dur = t1 - t0
                dtxt = f"{dur / 3600:.1f} ч" if dur >= 3600 else f"{dur / 60:.0f} мин"
                lines.append((f"{fmt_dt(t0)} … {fmt_dt(t1)}  ({dtxt})", ""))
            elif days:
                lines.append((f"активность: {min(days)} … {max(days)} "
                              f"({len(days)} дн.)", ""))
        lines.append((f"токены: input {h(tin)} · cache-wr {h(cw)} · "
                      f"cache-rd {h(cr)} · output {h(tout)}", "dim"))
        lines.append(("", ""))
        if tab == 3:
            agg = aggregate(sub, lambda r: r.model)
            lines.append(("модели:", "head"))
            namef = lambda k: k.replace("claude-", "")
        else:
            agg = aggregate(sub, lambda r: r.session)
            lines.append(("топ-чаты:", "head"))
            namef = lambda k: self.co.titles.get(k) or "(" + str(k)[:8] + ")"
        rows = sorted(agg.items(), key=lambda kv: -kv[1]["cost"])[:5]
        mxc = rows[0][1]["cost"] or 1 if rows else 1
        nw = inner - 25
        for k, a in rows:
            nm = namef(k)[:nw]
            lines.append((f" {nm:<{nw}} {bar(a['cost'] / mxc, 10):<10} "
                          f"{money(a['cost']):>11}", ""))

        hgt = len(lines) + 2
        if hgt > maxy - 2:
            lines = lines[: maxy - 4]
            hgt = len(lines) + 2
        y0 = max(1, (maxy - hgt) // 2)
        x0 = max(0, (maxx - w) // 2)
        tl, tr, bl, br, hz, vt = BOX
        title = f" {kind} "
        top_line = tl + hz * 2 + title + hz * max(0, w - 4 - len(title)) + tr
        self.add(scr, y0, x0, top_line[:w], self.c["head"])
        for i, (text, role) in enumerate(lines):
            y = y0 + 1 + i
            self.add(scr, y, x0, vt + " " * (w - 2) + vt, 0)
            self.add(scr, y, x0 + 2, text, self.c[role] if role else 0)
        self.add(scr, y0 + hgt - 1, x0, bl + hz * (w - 2) + br, self.c["head"])


def window(sel, n, h_):
    if n <= h_:
        return 0
    return max(0, min(sel - h_ // 2, n - h_))


# ---------------------------------------------------------------- main

def _codeset():
    # реальный codeset LC_CTYPE — именно его смотрит ncurses (в отличие от
    # getpreferredencoding, который на macOS врёт «UTF-8» даже под локалью C)
    try:
        return (locale.nl_langinfo(locale.CODESET) or "").upper()
    except (AttributeError, ValueError):
        return (locale.getpreferredencoding(False) or "").upper()


def setup_output():
    """Локаль ставим ДО curses.initscr (иначе бары рендерятся как «?»).
    Пытаемся получить UTF-8; если не вышло — переходим на ASCII-графику."""
    utf8 = False
    for loc in ("", "en_US.UTF-8", "C.UTF-8", "en_US.utf8", "C.utf8", "UTF-8"):
        try:
            locale.setlocale(locale.LC_ALL, loc)
        except locale.Error:
            continue
        if "UTF" in _codeset().replace("-", ""):
            utf8 = True
            break
    if os.environ.get("CCOST_UTF8"):
        utf8 = True           # ручной override: на Windows Terminal юникод ок
    try:                      # текстовый режим: не падать на не-UTF8 stdout
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    except Exception:
        pass
    if os.environ.get("CCOST_ASCII") or not utf8:
        set_ascii_glyphs()


def _dodge_broken_rep():
    """ncurses < 6.1 (macOS застрял на 6.0) с багом REP-оптимизации: повторяя
    многобайтовый символ, шлёт только его последний байт (█ → \\x88 + CSI n b),
    и терминал рисует кашу из битого UTF-8. Срабатывает только там, где
    terminfo заявляет rep (kitty) — уходим на xterm-256color без rep."""
    if getattr(curses, "ncurses_version", (99,)) >= (6, 1):
        return
    try:
        curses.setupterm(os.environ.get("TERM", ""))
        if curses.tigetstr("rep"):
            os.environ["TERM"] = "xterm-256color"
    except curses.error:
        pass


def main():
    arg = sys.argv[1] if len(sys.argv) > 1 else ""
    setup_output()
    co = Collector()
    co.scan()
    if arg in ("json", "-j", "--json"):
        print_json(co)
        return
    want_text = arg in ("report", "-r", "--report", "text")
    if want_text or not sys.stdout.isatty():
        print_text(co)
        return
    if curses is None:
        sys.stderr.write("для TUI нужен модуль curses "
                         "(Windows: pip install windows-curses); текстовый отчёт:\n")
        print_text(co)
        return
    _dodge_broken_rep()
    try:
        curses.wrapper(App(co).run)
    except Exception as e:  # фолбэк на текст при любой проблеме с curses
        sys.stderr.write(f"TUI недоступен ({e}); текстовый отчёт:\n")
        print_text(co)


if __name__ == "__main__":
    main()
