def find_app_browser():
    """Chromium-compatible browser for window mode (--app=URL): Edge is
    always present on Windows; on Linux try chromium/chrome/brave."""
    if sys.platform == "darwin":
        cands = [
            "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
            "/Applications/Chromium.app/Contents/MacOS/Chromium",
            "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge",
            "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
        ]
        return next((c for c in cands if os.path.exists(c)), None)
    if os.name == "nt":
        bases = [os.environ.get("ProgramFiles", r"C:\Program Files"),
                 os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)"),
                 os.environ.get("LOCALAPPDATA", "")]
        rels = [r"Microsoft\Edge\Application\msedge.exe",
                r"Google\Chrome\Application\chrome.exe",
                r"Chromium\Application\chrome.exe"]
        for base in bases:
            for rel in rels:
                p = os.path.join(base, rel)
                if base and os.path.exists(p):
                    return p
        return None
    for name in ("chromium", "chromium-browser", "google-chrome",
                 "google-chrome-stable", "brave-browser", "microsoft-edge"):
        p = shutil.which(name)
        if p:
            return p
    return None


def _gui_server(co, port=0):
    """Builds the dashboard HTTP server (does not call serve_forever)."""
    from http.server import BaseHTTPRequestHandler, HTTPServer
    from urllib.parse import urlparse, parse_qs
    import threading

    # first scan runs in the background: the window opens immediately with progress
    lock = threading.Lock()
    ready = threading.Event()

    def initial_scan():
        with lock:
            co.scan()
        ready.set()

    threading.Thread(target=initial_scan, daemon=True).start()
    threading.Thread(target=check_updates_loop, daemon=True).start()

    cache = {}

    def payload(period, day):
        if not ready.is_set():
            done, total = co.progress
            return json.dumps({"loading": {"done": done, "total": total}}).encode()
        with lock:
            if co.scan():
                cache.clear()
            key = (period, day)
            if key not in cache:
                cache[key] = json.dumps(gui_payload(co, period, day),
                                        ensure_ascii=False).encode("utf-8")
            return cache[key]

    def config_info():
        roots = source_roots()
        meta = {}
        for s in SOURCES:
            files = glob.glob(os.path.join(roots[s], "**", "*.jsonl"),
                              recursive=True)
            meta[s] = {"root": roots[s], "files": len(files),
                       "records": sum(1 for r in co.records if r.src == s)}
        return {"config": CFG, "meta": meta,
                "prices": {"anthropic": PRICE, "openai": PRICE_OPENAI}}

    class H(BaseHTTPRequestHandler):
        def log_message(self, *a):
            pass

        def _send(self, body, ctype):
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self):
            u = urlparse(self.path)
            if u.path == "/":
                body, ctype = GUI_HTML.encode("utf-8"), "text/html; charset=utf-8"
            elif u.path == "/data":
                q = parse_qs(u.query)
                try:
                    period = int(q.get("period", ["0"])[0])
                except ValueError:
                    period = 0
                day = q.get("day", [None])[0]
                if day and not re.fullmatch(r"\d{4}-\d{2}-\d{2}", day):
                    day = None
                body = payload(period % len(PERIODS), day)
                ctype = "application/json; charset=utf-8"
            elif u.path == "/config":
                body = json.dumps(config_info(), ensure_ascii=False).encode("utf-8")
                ctype = "application/json; charset=utf-8"
            else:
                self.send_response(404)
                self.end_headers()
                return
            self._send(body, ctype)

        def do_POST(self):
            if urlparse(self.path).path != "/config":
                self.send_response(404)
                self.end_headers()
                return
            try:
                n = int(self.headers.get("Content-Length", 0))
                upd = json.loads(self.rfile.read(n).decode("utf-8"))
            except (ValueError, TypeError):
                self.send_response(400)
                self.end_headers()
                return
            if isinstance(upd.get("sources"), dict):
                for sk, sv in upd["sources"].items():
                    if sk in CFG["sources"]:
                        CFG["sources"][sk] = bool(sv)
            if isinstance(upd.get("refresh_ms"), int):
                CFG["refresh_ms"] = max(1000, min(60000, upd["refresh_ms"]))
            if isinstance(upd.get("default_period"), int):
                CFG["default_period"] = upd["default_period"] % len(PERIODS)
            for key in ("menubar", "check_updates"):
                if isinstance(upd.get(key), bool):
                    CFG[key] = upd[key]
            reprice = False
            if isinstance(upd.get("prices"), dict):
                clean = {}
                for k, v in upd["prices"].items():
                    if isinstance(k, str) and isinstance(v, list) \
                            and 2 <= len(v) <= 3:
                        try:
                            clean[k] = [max(0.0, float(x)) for x in v]
                        except (TypeError, ValueError):
                            continue
                CFG["prices"] = clean
                reprice = True
            save_config(CFG)
            with lock:
                if reprice:
                    co.recost()
                cache.clear()
            body = json.dumps(config_info(), ensure_ascii=False).encode("utf-8")
            self._send(body, "application/json; charset=utf-8")

    srv = HTTPServer(("127.0.0.1", port), H)
    url = f"http://127.0.0.1:{srv.server_address[1]}/"
    return srv, url


def serve_gui(co, port=0, open_browser=True, app_browser=None):
    import threading
    import webbrowser

    srv, url = _gui_server(co, port)
    # flush is required: ccost.app reads the URL from the pipe
    print(f"ccost gui: {url}  (Ctrl-C to stop)", flush=True)
    if app_browser:
        # window mode: separate profile, otherwise chrome joins an existing
        # process and exits immediately — the window close cannot be tracked
        import subprocess
        prof = os.path.join(os.path.expanduser("~"), ".cache", "ccost-webapp")
        os.makedirs(prof, exist_ok=True)
        threading.Thread(target=srv.serve_forever, daemon=True).start()
        try:
            subprocess.run([app_browser, f"--app={url}",
                            f"--user-data-dir={prof}",
                            "--window-size=1240,860",
                            "--no-first-run", "--no-default-browser-check"],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except KeyboardInterrupt:
            pass
        return
    if open_browser:
        webbrowser.open(url)
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        pass


def native_window(co, port=0):
    """Native window via pywebview (bundled into the Windows binary): frameless
    on Windows, the dashboard draws its own chrome and window buttons.
    False — pywebview unavailable, caller falls back."""
    try:
        import webview
    except ImportError:
        return False
    import threading

    srv, url = _gui_server(co, port)
    threading.Thread(target=srv.serve_forever, daemon=True).start()
    state = {"max": False}

    class Api:
        def minimize(self):
            win.minimize()

        def toggle_max(self):
            try:
                if state["max"]:
                    win.restore()
                else:
                    win.maximize()
                state["max"] = not state["max"]
            except Exception:
                win.toggle_fullscreen()

        def close(self):
            win.destroy()

    win = webview.create_window(
        "ccost", url, js_api=Api(), width=1240, height=860,
        min_size=(760, 520), frameless=(os.name == "nt"),
        easy_drag=False, background_color="#0b0e12")
    webview.start()
    return True


# ---------------------------------------------------------------- TUI (curses)

TABS = ["Overview", "Models", "Days", "Chats", "Projects", "Tools", "Hours", "Week"]
WDAYS = ["mo", "tu", "we", "th", "fr", "sa", "su"]
TABLE_TABS = (1, 2, 3, 4, 5)


class App:
    def __init__(self, collector):
        self.co = collector
        self.tab = 0
        self.period = 0
        self.sortkey = "cost"          # cost | tok
        self.sel = [0] * len(TABS)
        self.detail = None             # (tab, key) — open details card
        self.live = True               # auto-refresh every ~2 s
        self._off = 0                  # current table scroll offset (for mouse)
        self._tab_spans = []           # tab x-ranges (for mouse)
        self.recompute()

    def recompute(self):
        self.f = apply_period(self.co.records, self.period)
        self.ov = overview(self.f)
        self.ag_models = aggregate(self.f, lambda r: r.model)
        days = aggregate(self.f, lambda r: r.day)
        days.pop("?", None)
        self.ag_days = days
        self.ag_chats = aggregate(self.f, lambda r: r.session)
        self.ag_proj = aggregate(self.f, lambda r: r.project)
        self.ag_tools = tools_agg(self.f)
        self.ag_hours = aggregate([r for r in self.f if r.hour >= 0], lambda r: r.hour)
        heat = defaultdict(float)
        for r in self.f:
            if r.hour >= 0 and r.wd >= 0:
                heat[(r.wd, r.hour)] += r.cost
        self.ag_heat = dict(heat)

    def sorted_rows(self, agg):
        if self.sortkey == "tok":
            return sorted(agg.items(), key=lambda kv: -tok(kv[1]))
        return sorted(agg.items(), key=lambda kv: -kv[1]["cost"])

    def rows_for(self, tab):
        if tab == 1:
            return self.sorted_rows(self.ag_models)
        if tab == 2:
            return sorted(self.ag_days.items())          # by date
        if tab == 3:
            return self.sorted_rows(self.ag_chats)
        if tab == 4:
            return self.sorted_rows(self.ag_proj)
        if tab == 5:
            key = (lambda kv: -kv[1]["calls"]) if self.sortkey == "tok" \
                else (lambda kv: -kv[1]["cost"])
            return sorted(self.ag_tools.items(), key=key)
        if tab == 6:
            return [(hh, self.ag_hours.get(hh)) for hh in range(24)]
        return []

    # ------------------------------------------------------------ loop
    def run(self, scr):
        curses.curs_set(0)
        scr.timeout(2000)              # live mode tick
        try:
            curses.mousemask(curses.ALL_MOUSE_EVENTS)
        except (curses.error, AttributeError):   # PDCurses may lack this
            pass
        self._init_colors()
        while True:
            self.draw(scr)
            while True:
                ch = scr.getch()
                if ch != -1:
                    break
                if self.live and self.co.scan():
                    self.recompute()
                    ch = -1
                    break
            if ch == -1:               # live tick with new data
                continue
            if ch == ord("r"):
                self.reload(scr)
                continue
            if ch == ord("p"):
                self.live = not self.live
                continue
            if not self.handle(ch):
                break

    def reload(self, scr):
        maxy, maxx = scr.getmaxyx()
        self.add(scr, maxy - 1, 1, "re-reading everything…".ljust(maxx - 2),
                 self.c["head"])
        scr.refresh()
        self.co = Collector()
        self.co.scan()
        self.recompute()

    def _init_colors(self):
        # Roles: dim (secondary text), head (headings), money ($), bar
        # (charts), tab (active tab). Each role value is a ready curses
        # attribute that can be |-ed with A_REVERSE etc.
        self.c = defaultdict(int)
        no_color = os.environ.get("NO_COLOR") is not None
        if no_color or not curses.has_colors():
            # no color — keep structure with attributes
            self.c["dim"] = curses.A_DIM
            self.c["head"] = curses.A_BOLD
            self.c["money"] = curses.A_BOLD
            self.c["bar"] = 0
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD
            return
        curses.start_color()
        try:
            curses.use_default_colors()   # background = the terminal's own
            bg = -1
        except (curses.error, AttributeError):
            bg = curses.COLOR_BLACK
        ncolors = getattr(curses, "COLORS", 8)
        if ncolors >= 256:
            # careful shades, readable on both dark and light backgrounds
            specs = [
                ("dim",   245, bg, 0),                 # gray, not blue
                ("head",  179, bg, curses.A_BOLD),     # warm yellow
                ("money", 71,  bg, 0),                 # green
                ("bar",   37,  bg, 0),                 # teal
                ("tab",   16,  37, curses.A_BOLD),     # dark on teal
                ("sel",   231, 24, curses.A_BOLD),     # selection: white on blue
            ]
        else:
            # 8/16 colors: no gray — use white + A_DIM
            specs = [
                ("dim",   curses.COLOR_WHITE,  bg, curses.A_DIM),
                ("head",  curses.COLOR_YELLOW, bg, curses.A_BOLD),
                ("money", curses.COLOR_GREEN,  bg, 0),
                ("bar",   curses.COLOR_CYAN,   bg, 0),
                ("tab",   curses.COLOR_BLACK,  curses.COLOR_CYAN, curses.A_BOLD),
                ("sel",   curses.COLOR_WHITE,  curses.COLOR_BLUE, curses.A_BOLD),
            ]
        for i, (name, fg, b, extra) in enumerate(specs, start=1):
            try:
                curses.init_pair(i, fg, b)
                self.c[name] = curses.color_pair(i) | extra
            except curses.error:
                self.c[name] = extra
        # if pairs failed, keep readability via reverse video
        if not self.c["tab"]:
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
        if not self.c["sel"]:
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD

    def handle(self, ch):
        if self.detail is not None:
            if ch == curses.KEY_MOUSE:
                try:
                    _, _, _, _, bs = curses.getmouse()
                except curses.error:
                    return True
                if bs & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED
                         | curses.BUTTON1_DOUBLE_CLICKED):
                    self.detail = None
                return True
            if ch in (27, ord("q"), curses.KEY_ENTER, 10, 13):
                self.detail = None
            return True
        if ch in (ord("q"), 27):
            return False
        n = len(TABS)
        if ch == curses.KEY_MOUSE:
            self._mouse()
        elif ch in (curses.KEY_RIGHT, ord("l"), ord("]"), ord("\t")):
            self.tab = (self.tab + 1) % n
        elif ch in (curses.KEY_LEFT, ord("h"), ord("[")):
            self.tab = (self.tab - 1) % n
        elif ord("1") <= ch < ord("1") + n:
            self.tab = ch - ord("1")
        elif ch in (curses.KEY_DOWN, ord("j")):
            self.sel[self.tab] += 1
        elif ch in (curses.KEY_UP, ord("k")):
            self.sel[self.tab] = max(0, self.sel[self.tab] - 1)
        elif ch == curses.KEY_NPAGE:
            self.sel[self.tab] += 10
        elif ch == curses.KEY_PPAGE:
            self.sel[self.tab] = max(0, self.sel[self.tab] - 10)
        elif ch in (curses.KEY_HOME, ord("g")):
            self.sel[self.tab] = 0
        elif ch in (curses.KEY_END, ord("G")):
            self.sel[self.tab] = 10 ** 9      # clamped in draw_table
        elif ch in (curses.KEY_ENTER, 10, 13) and self.tab in TABLE_TABS:
            rows = self.rows_for(self.tab)
            if rows:
                sel = min(self.sel[self.tab], len(rows) - 1)
                self.detail = (self.tab, rows[sel][0])
        elif ch == ord("f"):
            self.period = (self.period + 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("F"):
            self.period = (self.period - 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("s"):
            self.sortkey = "tok" if self.sortkey == "cost" else "cost"
        return True

    def _mouse(self):
        try:
            _, mx, my, _, bs = curses.getmouse()
        except curses.error:
            return
        b5 = getattr(curses, "BUTTON5_PRESSED", 0x200000)
        if bs & curses.BUTTON4_PRESSED:                       # wheel up
            self.sel[self.tab] = max(0, self.sel[self.tab] - 3)
            return
        if bs & b5:                                           # wheel down
            self.sel[self.tab] += 3
            return
        if not bs & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED
                     | curses.BUTTON1_DOUBLE_CLICKED):
            return
        if my == 1:                                           # tab click
            for i, (x0, x1) in enumerate(self._tab_spans):
                if x0 <= mx < x1:
                    self.tab = i
                    return
            return
        if my >= 4 and self.tab in TABLE_TABS:                # row click
            rows = self.rows_for(self.tab)
            idx = self._off + (my - 4)
            if 0 <= idx < len(rows):
                if idx == self.sel[self.tab] \
                        or bs & curses.BUTTON1_DOUBLE_CLICKED:
                    self.sel[self.tab] = idx
                    self.detail = (self.tab, rows[idx][0])    # second click = details
                else:
                    self.sel[self.tab] = idx

    def add(self, scr, y, x, s, attr=0):
        maxy, maxx = scr.getmaxyx()
        if y < 0 or y >= maxy or x < 0 or x >= maxx:
            return
        s = s[: maxx - x - 1]
        try:
            scr.addstr(y, x, s, attr)
        except (curses.error, UnicodeEncodeError):
            pass                           # screen edge / non-unicode console

    def draw(self, scr):
        scr.erase()
        maxy, maxx = scr.getmaxyx()
        head = self.ov
        cost = money(head["cost"]) if head else "$0.00"
        toks = h(head["tok"]) if head else "0"
        self.add(scr, 0, 1, "ccost", curses.A_BOLD)
        if self.live:
            self.add(scr, 0, 7, "live", self.c["money"])
        else:
            self.add(scr, 0, 7, "paused", self.c["dim"] | curses.A_REVERSE)
        right = f"{toks} tokens · {cost} · period: {PERIODS[self.period]}"
        self.add(scr, 0, max(14, maxx - len(right) - 2), right, self.c["dim"])
        # tabs
        x = 1
        self._tab_spans = []
        for i, name in enumerate(TABS):
            label = f" {i+1}·{name} "
            self._tab_spans.append((x, x + len(label)))
            attr = self.c["tab"] | curses.A_BOLD if i == self.tab else curses.A_DIM
            self.add(scr, 1, x, label, attr)
            x += len(label)
        self.add(scr, 2, 1, SEP * (maxx - 2), self.c["dim"])
        body_top = 3
        body_h = maxy - body_top - 1
        if not head:
            self.add(scr, body_top + 1, 2,
                     "no data for period '%s'" % PERIODS[self.period])
        elif self.tab == 0:
            self.draw_overview(scr, body_top, body_h, maxx)
        elif self.tab == 5:
            self.draw_tools(scr, body_top, body_h, maxx)
        elif self.tab == 6:
            self.draw_hours(scr, body_top, body_h, maxx)
        elif self.tab == 7:
            self.draw_heat(scr, body_top, body_h, maxx)
        else:
            self.draw_table(scr, body_top, body_h, maxx)
        if self.detail is not None:
            self.draw_detail(scr, maxy, maxx)
            foot = "Esc/Enter/click closes the card"
        else:
            foot = ("1-8 · ↑↓ · Enter details · f period · s sort(%s) · "
                    "p live · r reload · q quit" % self.sortkey)
        self.add(scr, maxy - 1, 1, foot, self.c["dim"])
        scr.refresh()

    def draw_overview(self, scr, top, h_, maxx):
        o = self.ov
        y = top + 1
        self.add(scr, y, 2, money(o["cost"]), self.c["money"] | curses.A_BOLD)
        self.add(scr, y, 16, f"{o['tok']:,} tokens", curses.A_BOLD)
        y += 2
        peak = f"{o['peak_hour'][0]:02d}:00" if o["peak_hour"][0] >= 0 else "—"
        lines = [
            ("messages", f"{o['msgs']:,}"),
            ("chats", f"{o['sessions']:,}"),
            ("active days", f"{o['ndays']}  ({o['first']} … {o['last']}) · "
                            f"streak {o['streak']} days"),
            ("average / day", money(o["avg_day"])),
            ("today", f"{money(o['today'])} · last hour {money(o['hour_cost'])}"),
            ("month forecast", f"{money(o['forecast'])} (so far {money(o['mtd'])})"),
            ("peak day", f"{o['busiest_day'][0]}  ({money(o['busiest_day'][1]['cost'])})"),
            ("peak hour", peak),
            ("top model", o["top_model"][0].replace("claude-", "")),
            ("cache reads", f"{o['cache_share']:.1f}% of all tokens"),
            ("cache saved", f"≈ {money(o['saved'])} "
                            f"(without cache ≈ {money(o['cost'] + o['saved'])})"),
        ]
        for name, val in lines:
            self.add(scr, y, 2, f"{name:>18} :", self.c["dim"])
            self.add(scr, y, 23, val)
            y += 1
        y += 1
        self.add(scr, y, 2, "tokens:", self.c["head"])
        self.add(scr, y, 12,
                 f"input {h(o['tin'])} · cache-wr {h(o['cw'])} · "
                 f"cache-rd {h(o['cr'])} · output {h(o['tout'])}")
        y += 1
        if self.co.unknown:
            self.add(scr, y, 2,
                     "no price (counted as $0): "
                     + ", ".join(sorted(self.co.unknown)),
                     self.c["head"])
            y += 1
        y += 1
        self.add(scr, y, 2, "cost by day:", self.c["head"])
        y += 1
        seq = fill_days(self.ag_days)
        if seq:
            width = min(maxx - 6, 80)
            shown = seq[-width:]
            vals = [c for _, c in shown]
            self.add(scr, y, 2, sparkline(vals, width), self.c["bar"])
            y += 1
            self.add(scr, y, 2,
                     f"{shown[0][0]}  →  {shown[-1][0]}   max ${max(vals):.2f}/day",
                     self.c["dim"])

    def draw_table(self, scr, top, h_, maxx):
        rows = self.rows_for(self.tab)
        sel = self.sel[self.tab] = min(self.sel[self.tab], max(0, len(rows) - 1))
        off = self._off = window(sel, len(rows), h_ - 1)
        mx = max((tok(a) for _, a in rows), default=1) or 1
        title = {1: "model", 2: "day", 3: "chat", 4: "project"}[self.tab]
        self.add(scr, top, 2, title, self.c["head"])
        self.add(scr, top, maxx - 37, f"{'input':>6}{'cache':>7}{'out':>7}",
                 self.c["head"] | curses.A_DIM)
        self.add(scr, top, maxx - 12, "$", self.c["head"])
        namew = max(12, maxx - 55)
        bx = 2 + namew + 1
        bw = max(0, min(12, maxx - 38 - bx))   # keep clear of numbers when narrow
        for i in range(off, min(len(rows), off + h_ - 1)):
            k, a = rows[i]
            y = top + 1 + (i - off)
            selected = i == sel
            if selected:                         # full-width highlight
                self.add(scr, y, 1, " " * (maxx - 2), self.c["sel"])
            a_txt = self.c["sel"] if selected else 0
            a_bar = self.c["sel"] if selected else self.c["bar"]
            a_dim = self.c["sel"] if selected else self.c["dim"]
            a_mon = self.c["sel"] if selected else self.c["money"]
            if self.tab == 1:
                name = k.replace("claude-", "")
            elif self.tab == 3:
                name = self.co.titles.get(k) or f"({k[:8]})"
            else:
                name = k
            mark = "> " if selected else "  "
            self.add(scr, y, 1, f"{mark}{name}"[:namew + 1].ljust(namew + 1), a_txt)
            self.add(scr, y, bx, bar(tok(a) / mx, bw), a_bar)
            self.add(scr, y, maxx - 37,
                     f"{h(a['tin']):>6}{h(a['cw'] + a['cr']):>7}{h(a['tout']):>7}", a_dim)
            self.add(scr, y, maxx - 13, f"{money(a['cost']):>11}", a_mon)
        if len(rows) > h_ - 1:
            self.add(scr, top, maxx - 46, f"[{sel + 1}/{len(rows)}]", self.c["dim"])

    def draw_tools(self, scr, top, h_, maxx):
        rows = self.rows_for(5)
        if not rows:
            self.add(scr, top + 1, 2, "no tool calls found")
            return
        sel = self.sel[5] = min(self.sel[5], len(rows) - 1)
        off = self._off = window(sel, len(rows), h_ - 1)
        mx = max(a["calls"] for _, a in rows) or 1
        self.add(scr, top, 2, "tool", self.c["head"])
        self.add(scr, top, maxx - 41, f"{'calls':>8}{'msgs':>9}",
                 self.c["head"] | curses.A_DIM)
        self.add(scr, top, maxx - 13, "$≈", self.c["head"])
        namew = max(12, maxx - 59)
        bx = 2 + namew + 1
        bw = max(0, min(12, maxx - 42 - bx))
        for i in range(off, min(len(rows), off + h_ - 1)):
            k, a = rows[i]
            y = top + 1 + (i - off)
            selected = i == sel
            if selected:
                self.add(scr, y, 1, " " * (maxx - 2), self.c["sel"])
            a_txt = self.c["sel"] if selected else 0
            a_bar = self.c["sel"] if selected else self.c["bar"]
            a_dim = self.c["sel"] if selected else self.c["dim"]
            a_mon = self.c["sel"] if selected else self.c["money"]
            mark = "> " if selected else "  "
            self.add(scr, y, 1, f"{mark}{k}"[:namew + 1].ljust(namew + 1), a_txt)
            self.add(scr, y, bx, bar(a["calls"] / mx, bw), a_bar)
            self.add(scr, y, maxx - 41, f"{a['calls']:>8,}{a['msgs']:>9,}", a_dim)
            self.add(scr, y, maxx - 13, f"{money(a['cost']):>11}", a_mon)
        if len(rows) > h_ - 1:
            self.add(scr, top, maxx - 51, f"[{sel + 1}/{len(rows)}]", self.c["dim"])

    def draw_hours(self, scr, top, h_, maxx):
        self.add(scr, top, 2, "activity by hour (local time)", self.c["head"])
        mxc = max((a["cost"] for a in self.ag_hours.values()), default=1) or 1
        bw = max(10, maxx - 30)
        for hh in range(24):
            y = top + 1 + hh
            if y >= top + h_:
                break
            a = self.ag_hours.get(hh)
            c = a["cost"] if a else 0
            msgs = a["msgs"] if a else 0
            self.add(scr, y, 2, f"{hh:02d}:00", self.c["dim"])
            self.add(scr, y, 8, bar(c / mxc, bw), self.c["bar"])
            self.add(scr, y, maxx - 20, f"{msgs:>5} msg {money(c):>9}", self.c["money"])

    def draw_heat(self, scr, top, h_, maxx):
        self.add(scr, top, 2, "cost by weekday and hour (local time)",
                 self.c["head"])
        heat = self.ag_heat
        mx = max(heat.values(), default=0) or 1
        x0 = 6
        ruler = "".join(f"{hh:02d}" + " " * 6 for hh in (0, 4, 8, 12, 16, 20))
        self.add(scr, top + 2, x0, ruler[:48], self.c["dim"])
        for wd in range(7):
            y = top + 3 + wd
            if y >= top + h_:
                return
            row_cost = 0.0
            cells = []
            for hh in range(24):
                v = heat.get((wd, hh), 0.0)
                row_cost += v
                cells.append(SPARK[spark_level(v, mx)] * 2)
            self.add(scr, y, 2, WDAYS[wd], self.c["dim"])
            self.add(scr, y, x0, "".join(cells), self.c["bar"])
            if row_cost:
                self.add(scr, y, x0 + 50, f"{money(row_cost):>10}", self.c["money"])
        y = top + 11
        if y < top + h_:
            self.add(scr, y, 2,
                     f"cell = one hour of the week · {FULL} = {money(mx)} (max/hour)",
                     self.c["dim"])

    # ------------------------------------------------------------ details card
    def _detail_records(self, tab, key):
        if tab == 5:
            return [r for r in self.f if key in r.tools]
        fld = {1: "model", 2: "day", 3: "session", 4: "project"}[tab]
        return [r for r in self.f if getattr(r, fld) == key]

    def draw_detail(self, scr, maxy, maxx):
        tab, key = self.detail
        sub = self._detail_records(tab, key)
        if not sub:
            self.detail = None
            return
        kind = {1: "model", 2: "day", 3: "chat", 4: "project", 5: "tool"}[tab]
        if tab == 1:
            name = key.replace("claude-", "")
        elif tab == 3:
            name = self.co.titles.get(key) or "(untitled)"
        else:
            name = key
        total = sum(r.cost for r in sub)
        tin = sum(r.tin for r in sub)
        tout = sum(r.tout for r in sub)
        cw = sum(r.cw for r in sub)
        cr = sum(r.cr for r in sub)
        ts = [r.t for r in sub if r.t]
        days = {r.day for r in sub if r.day != "?"}

        w = min(maxx - 4, 74)
        inner = w - 4
        lines = []                      # (text, role)
        for part in textwrap.wrap(name, inner)[:2] or [name[:inner]]:
            lines.append((part, "head"))
        if tab == 3:
            lines.append((f"id {str(key)[:8]} · project {sub[0].project}", "dim"))
        else:
            ns = len({r.session for r in sub})
            lines.append((f"chats: {ns}", "dim"))
        lines.append(("", ""))
        if tab == 5:
            calls = sum(r.tools.count(key) for r in sub)
            lines.append((f"{calls:,} calls · {len(sub):,} messages · "
                          f"{money(total)} in those messages", "money"))
        else:
            lines.append((f"{money(total)} · {len(sub):,} messages · "
                          f"{money(total / len(sub))}/message", "money"))
        if ts:
            t0, t1 = min(ts), max(ts)
            if tab == 3:
                dur = t1 - t0
                dtxt = f"{dur / 3600:.1f} h" if dur >= 3600 else f"{dur / 60:.0f} min"
                lines.append((f"{fmt_dt(t0)} … {fmt_dt(t1)}  ({dtxt})", ""))
            elif days:
                lines.append((f"active: {min(days)} … {max(days)} "
                              f"({len(days)} days)", ""))
        lines.append((f"tokens: input {h(tin)} · cache-wr {h(cw)} · "
                      f"cache-rd {h(cr)} · output {h(tout)}", "dim"))
        lines.append(("", ""))
        if tab == 3:
            agg = aggregate(sub, lambda r: r.model)
            lines.append(("models:", "head"))
            namef = lambda k: k.replace("claude-", "")
        else:
            agg = aggregate(sub, lambda r: r.session)
            lines.append(("top chats:", "head"))
            namef = lambda k: self.co.titles.get(k) or "(" + str(k)[:8] + ")"
        rows = sorted(agg.items(), key=lambda kv: -kv[1]["cost"])[:5]
        mxc = rows[0][1]["cost"] or 1 if rows else 1
        nw = inner - 25
        for k, a in rows:
            nm = namef(k)[:nw]
            lines.append((f" {nm:<{nw}} {bar(a['cost'] / mxc, 10):<10} "
                          f"{money(a['cost']):>11}", ""))

        hgt = len(lines) + 2
        if hgt > maxy - 2:
            lines = lines[: maxy - 4]
            hgt = len(lines) + 2
        y0 = max(1, (maxy - hgt) // 2)
        x0 = max(0, (maxx - w) // 2)
        tl, tr, bl, br, hz, vt = BOX
        title = f" {kind} "
        top_line = tl + hz * 2 + title + hz * max(0, w - 4 - len(title)) + tr
        self.add(scr, y0, x0, top_line[:w], self.c["head"])
        for i, (text, role) in enumerate(lines):
            y = y0 + 1 + i
            self.add(scr, y, x0, vt + " " * (w - 2) + vt, 0)
            self.add(scr, y, x0 + 2, text, self.c[role] if role else 0)
        self.add(scr, y0 + hgt - 1, x0, bl + hz * (w - 2) + br, self.c["head"])


def window(sel, n, h_):
    if n <= h_:
        return 0
    return max(0, min(sel - h_ // 2, n - h_))


# ---------------------------------------------------------------- main

def _codeset():
    # the real LC_CTYPE codeset — this is what ncurses consults (unlike
    # getpreferredencoding, which on macOS claims UTF-8 even under the C locale)
    try:
        return (locale.nl_langinfo(locale.CODESET) or "").upper()
    except (AttributeError, ValueError):
        return (locale.getpreferredencoding(False) or "").upper()


def setup_output():
    """Set the locale BEFORE curses.initscr (or bars render as "?").
    Try to get UTF-8; if that fails, switch to ASCII glyphs."""
    utf8 = False
    for loc in ("", "en_US.UTF-8", "C.UTF-8", "en_US.utf8", "C.utf8", "UTF-8"):
        try:
            locale.setlocale(locale.LC_ALL, loc)
        except locale.Error:
            continue
        if "UTF" in _codeset().replace("-", ""):
            utf8 = True
            break
    if os.environ.get("CCOST_UTF8"):
        utf8 = True           # manual override: Windows Terminal handles unicode
    try:                      # text mode: do not crash on non-UTF8 stdout
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    except Exception:
        pass
    if os.environ.get("CCOST_ASCII") or not utf8:
        set_ascii_glyphs()


def _dodge_broken_rep():
    """ncurses < 6.1 (macOS ships 6.0) has a REP optimization bug: repeating a
    multibyte character it emits only its final byte, and the terminal renders
    broken UTF-8. Triggers only where terminfo declares rep (kitty) — switch
    to xterm-256color, which has no rep."""
    if getattr(curses, "ncurses_version", (99,)) >= (6, 1):
        return
    try:
        curses.setupterm(os.environ.get("TERM", ""))
        if curses.tigetstr("rep"):
            os.environ["TERM"] = "xterm-256color"
    except curses.error:
        pass


def main():
    arg = sys.argv[1] if len(sys.argv) > 1 else ""
    if arg == "--probe":                # CI: verify webview is bundled
        try:
            import webview              # noqa: F401
            msg = "ok"
        except Exception as e:
            msg = "fail: %r" % (e,)
        with open("ccost-probe.txt", "w") as fh:
            fh.write(msg)
        return
    setup_output()
    co = Collector()
    if arg in ("gui", "web", "-g"):     # scan runs in the background — window opens now
        rest = sys.argv[2:]
        port = next((int(a) for a in rest if a.isdigit()), 0)
        serve_gui(co, port, open_browser="--no-open" not in rest)
        return
    # app window; on the Windows binary this is also the default mode
    if arg == "app" or (arg == "" and os.name == "nt"
                        and getattr(sys, "frozen", False)):
        rest = sys.argv[2:]
        port = next((int(a) for a in rest if a.isdigit()), 0)
        if native_window(co, port):     # pywebview: custom chrome
            return
        b = find_app_browser()          # fallback: chromium --app
        if not b:
            print("Chrome/Chromium/Edge not found — opening a browser tab",
                  flush=True)
        serve_gui(co, port, open_browser=b is None, app_browser=b)
        return
    co.scan()
    if arg in ("json", "-j", "--json"):
        print_json(co)
        return
    want_text = arg in ("report", "-r", "--report", "text")
    if want_text or not (sys.stdout and sys.stdout.isatty()):
        print_text(co)
        return
    if curses is None:
        sys.stderr.write("the TUI needs the curses module "
                         "(Windows: pip install windows-curses); text report:\n")
        print_text(co)
        return
    _dodge_broken_rep()
    try:
        curses.wrapper(App(co).run)
    except Exception as e:  # fall back to text on any curses problem
        sys.stderr.write(f"TUI unavailable ({e}); text report:\n")
        print_text(co)


if __name__ == "__main__":
    import multiprocessing
    multiprocessing.freeze_support()   # parallel parse inside frozen binaries
    main()
