# ---------------------------------------------------------------- prices

# Anthropic: $ per 1M tokens (input, output); cache read = 0.1x input
PRICE = {
    "claude-fable-5":            (10, 50),
    "claude-opus-4-8":           (5, 25),
    "claude-opus-4-7":           (5, 25),
    "claude-opus-4-6":           (5, 25),
    "claude-opus-4-5":           (5, 25),
    "claude-sonnet-5":           (3, 15),
    "claude-sonnet-4-6":         (3, 15),
    "claude-haiku-4-5":          (1, 5),
}
# OpenAI (Codex): $ per 1M tokens (input, output, cached input) —
# per developers.openai.com/api/docs/pricing, July 2026
PRICE_OPENAI = {
    "gpt-5.6-sol":   (5.0, 30.0, 0.50),
    "gpt-5.6-terra": (2.5, 15.0, 0.25),
    "gpt-5.6-luna":  (1.0, 6.0, 0.10),
    "gpt-5.5":       (5.0, 30.0, 0.50),
    "gpt-5.4":       (2.5, 15.0, 0.25),
    "gpt-5.3-codex": (1.75, 14.0, 0.175),
    "gpt-5.2-codex": (1.75, 14.0, 0.175),
    "gpt-5.2":       (1.25, 10.0, 0.125),
    "gpt-5.1":       (1.25, 10.0, 0.125),
    "gpt-5-codex":   (1.25, 10.0, 0.125),
    "gpt-5-mini":    (0.25, 2.0, 0.025),
    "gpt-5-nano":    (0.05, 0.40, 0.005),
    "gpt-5":         (1.25, 10.0, 0.125),
    "codex-5.6-sol": (5.0, 30.0, 0.50),
}
CACHE_W_5M = 1.25    # anthropic: 5-minute ephemeral cache write = 1.25x input
CACHE_W_1H = 2.0     # anthropic: 1-hour ephemeral cache write = 2x input
CACHE_READ = 0.10    # anthropic: cache read = 0.1x input

TS_FORMATS = ("%Y-%m-%dT%H:%M:%S.%fZ", "%Y-%m-%dT%H:%M:%SZ")

# ---------------------------------------------------------------- config

CONFIG_PATH = os.path.expanduser("~/.ccost.json")
VERSION = "1.4.2"

DEFAULT_CFG = {"sources": {"claude": True, "codex": True},
               "claude_root": None, "codex_root": None,
               "refresh_ms": 3000, "default_period": 0,
               "menubar": True, "check_updates": True,
               "prices": {}}     # price overrides: {model: [in, out(, cached)]}
SOURCES = ("claude", "codex")


def load_config():
    cfg = json.loads(json.dumps(DEFAULT_CFG))
    try:
        with open(CONFIG_PATH, encoding="utf-8") as fh:
            user = json.load(fh)
        for k, v in user.items():
            if k == "sources" and isinstance(v, dict):
                for sk, sv in v.items():
                    if sk in cfg["sources"]:
                        cfg["sources"][sk] = bool(sv)
            elif k in cfg:
                cfg[k] = v
    except (OSError, ValueError):
        pass
    return cfg


def save_config(cfg):
    try:
        with open(CONFIG_PATH, "w", encoding="utf-8") as fh:
            json.dump(cfg, fh, ensure_ascii=False, indent=2)
    except OSError:
        pass


CFG = load_config()


def claude_root():
    # CCOST_ROOT — e.g. point Windows at WSL data:
    # CCOST_ROOT=\\wsl.localhost\Ubuntu\home\user\.claude\projects
    return (os.environ.get("CCOST_ROOT") or CFG.get("claude_root")
            or os.path.expanduser("~/.claude/projects"))


def codex_root():
    return (os.environ.get("CCOST_CODEX_ROOT") or CFG.get("codex_root")
            or os.path.expanduser("~/.codex/sessions"))


def source_roots():
    return {"claude": claude_root(), "codex": codex_root()}


def price_for(model):
    """(input, output, cached) $/1M; longest-prefix match (so gpt-5 does not
    shadow gpt-5.4). Config overrides win. None — model is not priced."""
    ov = CFG.get("prices") or {}
    hit = ov.get(model)
    if hit is None:
        for k in sorted(ov, key=len, reverse=True):
            if model.startswith(k):
                hit = ov[k]
                break
    if hit:
        pin, pout = float(hit[0]), float(hit[1])
        pc = float(hit[2]) if len(hit) > 2 else pin * CACHE_READ
        return pin, pout, pc
    for table, anthropic in ((PRICE, True), (PRICE_OPENAI, False)):
        p = table.get(model)
        if p is None:
            for k in sorted(table, key=len, reverse=True):
                if model.startswith(k):
                    p = table[k]
                    break
        if p is not None:
            if anthropic:
                return p[0], p[1], p[0] * CACHE_READ
            return p
    return None


def cost_of(model, tin, tout, cw, cr, cw1h):
    """One formula for both providers: codex records have cw=0 and keep cached
    input in cr, priced at its own rate. None — model is not priced."""
    p = price_for(model)
    if p is None:
        return None
    pin, pout, pcached = p
    cw5 = max(cw - cw1h, 0)
    return (tin * pin + tout * pout + cr * pcached
            + cw5 * pin * CACHE_W_5M + cw1h * pin * CACHE_W_1H) / 1e6


def parse_ts(s):
    if not s:
        return 0.0
    for fmt in TS_FORMATS:
        try:
            return datetime.strptime(s, fmt).replace(tzinfo=timezone.utc).timestamp()
        except ValueError:
            continue
    return 0.0


def h(n):
    """Human-readable token count: 1234567 -> 1.2M (never "1000.0K")."""
    for unit, size in (("B", 1e9), ("M", 1e6), ("K", 1e3)):
        if n >= size * 0.9995:               # 999950 -> 1.0M, not 1000.0K
            return f"{n / size:.1f}{unit}"
    return str(int(n))


def money(x):
    return f"${x:,.2f}"


def fmt_dt(t):
    return datetime.fromtimestamp(t).strftime("%Y-%m-%d %H:%M")


ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[0-9A-Za-z]")


def clean_text(s):
    """Chat titles are arbitrary user text: raw ANSI codes, emoji, CJK. Wide
    characters break column layout (curses counts columns, python counts code
    points) and old ncurses mangles them at the screen edge — replace wide
    glyphs with a middle dot and strip control characters."""
    s = ANSI_RE.sub("", s)
    out = []
    for ch in s:
        if ch == "�" or unicodedata.category(ch)[0] == "C":
            out.append(" ")            # ZWSP etc: keep a space so words do not fuse
            continue
        if ord(ch) > 0xFFFF or unicodedata.east_asian_width(ch) in ("W", "F"):
            out.append("·")
            continue
        out.append(ch)
    return "".join(out)


# ---------------------------------------------------------------- data collection

class Rec:
    __slots__ = ("t", "model", "session", "project", "src",
                 "tin", "tout", "cw", "cr", "cw1h",
                 "cost", "day", "hour", "wd", "tools")


class Collector:
    """Incremental JSONL parser: remembers how far each file has been read and
    on repeated scan() only parses appended bytes — this is what makes live
    mode possible. Sources: Claude Code (dedup by message.id, field-wise max)
    and Codex/OpenAI (token_count events)."""

    def __init__(self, use_cache=True):
        self.by_mid = {}
        self.records = []
        self.titles = {}
        self.unknown = set()
        self.pos = {}            # path -> byte offset parsed so far
        self.seen_tools = set()  # tool_use/function_call ids (call dedup)
        self.seen_codex = set()  # codex token_count event dedup
        self.codex_state = {}    # path -> {sid, proj, model, tools} (file state)
        self.dirty = set()       # records whose cost needs recomputing
        self.progress = (0, 0)   # (files parsed, total) — for GUI progress
        self.track_keys = False  # worker mode: remember each record's dedup key
        self._rec_keys = {}
        self._saved_at = 0.0
        if use_cache:
            self.load_cache()    # warm start: snapshot instead of a full re-parse

    # ------------------------------------------------------------ snapshot
    # A full parse of 1+GB of JSONL takes seconds; a snapshot of parsed state
    # on disk brings startup down to a fraction of a second — only new bytes
    # get read.
    _REC_FIELDS = ("t", "model", "session", "project", "src", "tin", "tout",
                   "cw", "cr", "cw1h", "cost", "day", "hour", "wd", "tools")

    @staticmethod
    def _cache_ver():
        return (2,)              # prices are not part of the snapshot — recost() on load

    @staticmethod
    def _cache_path():
        d = os.path.join(os.path.expanduser("~"), ".cache", "ccost")
        try:
            os.makedirs(d, exist_ok=True)
        except OSError:
            pass
        return os.path.join(d, "state.pickle")

    def load_cache(self):
        import pickle
        try:
            with open(self._cache_path(), "rb") as fh:
                data = pickle.load(fh)
            if data.get("ver") != self._cache_ver():
                return False
        except Exception:
            return False
        for tup in data["recs"]:
            r = Rec()
            for f, v in zip(self._REC_FIELDS, tup):
                setattr(r, f, v)
            self.records.append(r)
        for mid, i in data["mids"].items():
            self.by_mid[mid] = self.records[i]
        self.pos = data["pos"]
        self.titles = data["titles"]
        self.seen_tools = data["seen_tools"]
        self.seen_codex = data["seen_codex"]
        self.codex_state = data["codex_state"]
        self._saved_at = time.time()
        self.recost()            # prices may have changed since the snapshot
        return True

    def recost(self):
        """Recompute the cost of every record at current prices
        (including config overrides)."""
        self.unknown = set()
        for r in self.records:
            c = cost_of(r.model, r.tin, r.tout, r.cw, r.cr, r.cw1h)
            if c is None:
                self.unknown.add(r.model)
                c = 0.0
            r.cost = c

    def save_cache(self):
        import pickle
        idx = {id(r): i for i, r in enumerate(self.records)}
        data = {
            "ver": self._cache_ver(),
            "recs": [tuple(getattr(r, f) for f in self._REC_FIELDS)
                     for r in self.records],
            "mids": {mid: idx[id(r)] for mid, r in self.by_mid.items()
                     if isinstance(mid, str) and id(r) in idx},
            "pos": self.pos, "titles": self.titles, "unknown": self.unknown,
            "seen_tools": self.seen_tools, "seen_codex": self.seen_codex,
            "codex_state": self.codex_state,
        }
        tmp = self._cache_path() + ".tmp"
        try:
            with open(tmp, "wb") as fh:
                pickle.dump(data, fh, protocol=4)
            os.replace(tmp, self._cache_path())
            self._saved_at = time.time()
        except OSError:
            pass

    def scan(self):
        """Read new/changed files of enabled sources.
        True — data changed."""
        changed = False
        jobs = []
        roots = source_roots()
        for src in SOURCES:
            if not CFG["sources"].get(src, True):
                continue
            pat = os.path.join(roots[src], "**", "*.jsonl")
            jobs += [(src, fp) for fp in glob.glob(pat, recursive=True)]
        pending = []
        total_new = 0
        for src, fp in jobs:
            try:
                size = os.path.getsize(fp)
            except OSError:
                continue
            done = self.pos.get(fp, 0)
            if size != done:
                pending.append((src, fp))
                total_new += size - done if size > done else size
        # cold start: hundreds of megabytes get parsed across processes
        if total_new > 200 * 1024 * 1024 and len(pending) > 8:
            try:
                if self._scan_parallel(pending):
                    changed = True
                pending = []
            except Exception:
                pass                 # fall back to the sequential parse below
        for n, (src, fp) in enumerate(pending):
            self.progress = (n + 1, len(pending))
            if self._parse_file(src, fp):
                changed = True
        if self.dirty:
            for r in self.dirty:
                c = cost_of(r.model, r.tin, r.tout, r.cw, r.cr, r.cw1h)
                if c is None:
                    self.unknown.add(r.model)
                    c = 0.0
                r.cost = c
            self.dirty.clear()
            changed = True
        if changed and time.time() - self._saved_at > 300:
            self.save_cache()      # every ~5 min; a loss just means re-reading the tail
        return changed

    def _parse_file(self, src, fp):
        """Read one file from its saved offset. True — something was parsed."""
        try:
            size = os.path.getsize(fp)
        except OSError:
            return False
        done = self.pos.get(fp, 0)
        if size == done:
            return False
        if size < done:
            done = 0                 # file was rewritten — re-read (dedup saves us)
        try:
            fh = open(fp, "rb")
        except OSError:
            return False
        with fh:
            fh.seek(done)
            data = fh.read()
        end = data.rfind(b"\n") + 1
        if end == 0:
            return False             # incomplete line — wait for the next tick
        self.pos[fp] = done + end
        changed = False
        for raw in data[:end].split(b"\n"):
            if not raw:
                continue
            line = raw.decode("utf-8", "replace")
            if src == "claude":
                if self._line(line):
                    changed = True
            elif self._line_codex(fp, line):
                changed = True
        return changed

    def _scan_parallel(self, pending):
        """Cold parse across processes; merge with dedup: claude — field-wise
        max by message.id, codex — by event key."""
        import multiprocessing as mp
        nproc = max(2, min(4, os.cpu_count() or 2))
        chunks = [c for c in (pending[i::nproc] for i in range(nproc)) if c]
        self.progress = (0, len(pending))
        done_files = 0
        changed = False
        with mp.get_context("spawn").Pool(len(chunks)) as pool:
            for part in pool.imap_unordered(_parse_chunk, chunks):
                done_files += part["files"]
                self.progress = (done_files, len(pending))
                if self._merge_partial(part):
                    changed = True
        return changed

    def _merge_partial(self, part):
        changed = False
        for tup, key in zip(part["recs"], part["keys"]):
            r = Rec()
            for f, v in zip(self._REC_FIELDS, tup):
                setattr(r, f, v)
            if key is not None and key[0] == "mid":
                cur = self.by_mid.get(key[1])
                if cur is not None:      # copy of a message seen by another worker
                    for f in ("tin", "tout", "cw", "cr", "cw1h"):
                        v = getattr(r, f)
                        if v > getattr(cur, f):
                            setattr(cur, f, v)
                    self.dirty.add(cur)
                    changed = True
                    continue
                self.by_mid[key[1]] = r
            elif key is not None and key[0] == "cx":
                if key[1] in self.seen_codex:
                    continue
                self.seen_codex.add(key[1])
            self.records.append(r)
            self.dirty.add(r)
            changed = True
        for sid, t in part["titles"].items():
            self.titles.setdefault(sid, t)
        self.seen_tools |= part["seen_tools"]
        self.pos.update(part["pos"])
        self.codex_state.update(part["codex_state"])
        return changed

    def _line(self, line):
        if '"usage"' not in line and '"type":"user"' not in line \
                and '"type": "user"' not in line:
            return False
        try:
            o = json.loads(line)
        except ValueError:
            return False
        typ = o.get("type")
        if typ == "user":
            self._maybe_title(o)
            return False
        if typ != "assistant":
            return False
        m = o.get("message", {})
        u = m.get("usage")
        if not u:
            return False
        tin = u.get("input_tokens", 0)
        tout = u.get("output_tokens", 0)
        cw = u.get("cache_creation_input_tokens", 0)
        cr = u.get("cache_read_input_tokens", 0)
        if tin + tout + cw + cr == 0:
            return False               # synthetic/empty messages
        cc = u.get("cache_creation") or {}
        cw1h = cc.get("ephemeral_1h_input_tokens", 0)
        mid = m.get("id") or object()  # no id — do not dedup
        r = self.by_mid.get(mid)
        touched = False
        if r is None:
            r = Rec()
            r.src = "claude"
            r.model = m.get("model", "unknown")
            r.session = o.get("sessionId", "?")
            cwd = o.get("cwd") or ""
            r.project = os.path.basename(cwd) or "?"
            r.tin, r.tout, r.cw, r.cr, r.cw1h = tin, tout, cw, cr, cw1h
            r.t = 0.0
            r.cost = 0.0
            r.day, r.hour, r.wd = "?", -1, -1
            r.tools = ()
            self.by_mid[mid] = r
            self.records.append(r)
            if self.track_keys:
                self._rec_keys[id(r)] = ("mid", mid) if isinstance(mid, str) else None
            touched = True
        else:
            # streaming: lines of one message with growing usage
            for f, v in (("tin", tin), ("tout", tout), ("cw", cw),
                         ("cr", cr), ("cw1h", cw1h)):
                if v > getattr(r, f):
                    setattr(r, f, v)
                    touched = True
        if not r.t:
            t = parse_ts(o.get("timestamp"))
            if t:
                r.t = t
                lt = datetime.fromtimestamp(t)
                r.day = lt.strftime("%Y-%m-%d")
                r.hour = lt.hour
                r.wd = lt.weekday()
        names = self._tool_uses(m.get("content"))
        if names:
            r.tools = r.tools + tuple(names)
            touched = True
        if touched:
            self.dirty.add(r)
        return touched

    def _tool_uses(self, content):
        if not isinstance(content, list):
            return []
        names = []
        for b in content:
            if not (isinstance(b, dict) and b.get("type") == "tool_use"):
                continue
            bid = b.get("id")
            if bid:
                if bid in self.seen_tools:
                    continue           # duplicate from resume/fork
                self.seen_tools.add(bid)
            names.append(b.get("name") or "?")
        return names

    def _maybe_title(self, o):
        if o.get("isSidechain"):
            return
        sid = o.get("sessionId")
        if not sid or sid in self.titles:
            return
        c = o.get("message", {}).get("content")
        text = None
        if isinstance(c, str):
            text = c
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and b.get("type") == "text":
                    text = b.get("text")
                    break
        if not text:
            return
        text = " ".join(clean_text(text).split())
        if text and not text.startswith("<") and not text.startswith("Caveat"):
            self.titles[sid] = text[:80]

    # ------------------------------------------------------------ codex
    def _line_codex(self, fp, line):
        """Codex CLI rollout files (~/.codex/sessions): usage arrives as
        token_count events (last_token_usage = one API request), model and
        cwd come from turn_context/session_meta."""
        if '"token_count"' not in line and '"session_meta"' not in line \
                and '"turn_context"' not in line and '"user_message"' not in line \
                and '"function_call"' not in line:
            return False
        try:
            o = json.loads(line)
        except ValueError:
            return False
        st = self.codex_state.setdefault(
            fp, {"sid": os.path.basename(fp)[:-6], "proj": "?",
                 "model": "unknown", "tools": []})
        typ = o.get("type")
        pay = o.get("payload") or {}
        if typ == "session_meta":
            st["sid"] = pay.get("id") or st["sid"]
            cwd = pay.get("cwd") or ""
            st["proj"] = os.path.basename(cwd) or "?"
            return False
        if typ == "turn_context":
            st["model"] = pay.get("model") or st["model"]
            cwd = pay.get("cwd") or ""
            if cwd:
                st["proj"] = os.path.basename(cwd) or st["proj"]
            return False
        if typ == "response_item":
            if pay.get("type") != "function_call":
                return False
            cid = pay.get("call_id") or pay.get("id")
            if cid:
                if cid in self.seen_tools:
                    return False
                self.seen_tools.add(cid)
            st["tools"].append(pay.get("name") or "?")
            return False
        if typ != "event_msg":
            return False
        pt = pay.get("type")
        if pt == "user_message":
            if st["sid"] not in self.titles:
                text = " ".join(clean_text(str(pay.get("message") or "")).split())
                if text:
                    self.titles[st["sid"]] = text[:80]
            return False
        if pt != "token_count":
            return False
        u = (pay.get("info") or {}).get("last_token_usage") or {}
        tin_all = u.get("input_tokens", 0)
        cached = u.get("cached_input_tokens", 0)
        tout = u.get("output_tokens", 0)
        if tin_all + tout == 0:
            return False
        key = (st["sid"], o.get("timestamp"), tin_all, tout,
               u.get("total_tokens", 0))
        if key in self.seen_codex:
            return False               # duplicate from resume
        self.seen_codex.add(key)
        r = Rec()
        r.src = "codex"
        r.model = st["model"]
        r.session = st["sid"]
        r.project = st["proj"]
        r.tin = max(tin_all - cached, 0)   # cached is a subset of input
        r.cr = cached                      # cache reads, priced separately
        r.cw = r.cw1h = 0
        r.tout = tout
        r.tools = tuple(st["tools"])
        st["tools"] = []
        r.t = 0.0
        r.cost = 0.0
        r.day, r.hour, r.wd = "?", -1, -1
        if self.track_keys:
            self._rec_keys[id(r)] = ("cx", key)
        t = parse_ts(o.get("timestamp"))
        if t:
            r.t = t
            lt = datetime.fromtimestamp(t)
            r.day = lt.strftime("%Y-%m-%d")
            r.hour = lt.hour
            r.wd = lt.weekday()
        self.records.append(r)
        self.dirty.add(r)
        return True


def _parse_chunk(files):
    """Worker for the parallel cold parse (Collector._scan_parallel): parses
    its batch of files and returns serializable state."""
    co = Collector(use_cache=False)
    co.track_keys = True
    for src, fp in files:
        co._parse_file(src, fp)
    return {
        "recs": [tuple(getattr(r, f) for f in Collector._REC_FIELDS)
                 for r in co.records],
        "keys": [co._rec_keys.get(id(r)) for r in co.records],
        "titles": co.titles, "seen_tools": co.seen_tools,
        "pos": co.pos, "codex_state": co.codex_state,
        "files": len(files),
    }


# ---------------------------------------------------------------- aggregation

def tok(a):
    return a["tin"] + a["tout"] + a["cw"] + a["cr"]


def aggregate(records, keyfn):
    d = {}
    for r in records:
        k = keyfn(r)
        a = d.get(k)
        if a is None:
            a = d[k] = {"tin": 0, "tout": 0, "cw": 0, "cr": 0,
                        "cost": 0.0, "msgs": 0, "mc": defaultdict(int)}
        a["tin"] += r.tin
        a["tout"] += r.tout
        a["cw"] += r.cw
        a["cr"] += r.cr
        a["cost"] += r.cost
        a["msgs"] += 1
        a["mc"][r.model] += r.tin + r.tout + r.cw + r.cr
    return d


def tools_agg(records):
    """Tool call counter; a message's cost is split evenly across its calls
    (approximate attribution)."""
    d = {}
    for r in records:
        if not r.tools:
            continue
        n = len(r.tools)
        for name, c in Counter(r.tools).items():
            a = d.setdefault(name, {"calls": 0, "msgs": 0, "cost": 0.0})
            a["calls"] += c
            a["msgs"] += 1
            a["cost"] += r.cost * c / n
    return d


def top_model(a):
    return max(a["mc"].items(), key=lambda kv: kv[1])[0] if a["mc"] else "?"


def cache_saved(records):
    """How much the cache saved vs a world without it (reads at full price,
    but no write premiums either)."""
    saved = 0.0
    for r in records:
        p = price_for(r.model)
        if not p:
            continue
        pin, _, pcached = p
        cw5 = max(r.cw - r.cw1h, 0)
        saved += (r.cr * (pin - pcached)
                  - cw5 * pin * (CACHE_W_5M - 1)
                  - r.cw1h * pin * (CACHE_W_1H - 1)) / 1e6
    return saved


def fun_records(records, titles):
    """All-time records — fun facts for the dashboard."""
    if not records:
        return []
    hourly = defaultdict(float)
    daily = defaultdict(float)
    day_tok = defaultdict(int)
    sess = {}
    tools = Counter()
    for r in records:
        if r.day != "?":
            daily[r.day] += r.cost
            day_tok[r.day] += r.tin + r.tout + r.cw + r.cr
            if r.hour >= 0:
                hourly[(r.day, r.hour)] += r.cost
        if r.t:
            a = sess.setdefault(r.session, [r.t, r.t, 0.0])
            a[0] = min(a[0], r.t)
            a[1] = max(a[1], r.t)
            a[2] += r.cost
        for name in r.tools:
            tools[name] += 1
    out = []

    def add(label, value, sub):
        out.append({"label": label, "value": value, "sub": sub})

    if hourly:
        (d, hh), c = max(hourly.items(), key=lambda kv: kv[1])
        add("priciest hour", money(c), f"{d} {hh:02d}:00")
    if daily:
        d, c = max(daily.items(), key=lambda kv: kv[1])
        add("priciest day", money(c), d)
    if day_tok:
        d, n = max(day_tok.items(), key=lambda kv: kv[1])
        add("most tokens in a day", h(n), d)
    if sess:
        sid, (t0, t1, c) = max(sess.items(), key=lambda kv: kv[1][2])
        add("priciest chat", money(c), titles.get(sid, "(" + str(sid)[:8] + ")")[:44])
        sid, (t0, t1, c) = max(sess.items(), key=lambda kv: kv[1][1] - kv[1][0])
        dur = t1 - t0
        add("longest chat", f"{dur / 3600:.1f} h",
            titles.get(sid, "(" + str(sid)[:8] + ")")[:44])
    ds = sorted(daily)
    if ds:
        best_n, best_end, n, prev = 1, ds[0], 1, ds[0]
        for d in ds[1:]:
            try:
                gap = (date.fromisoformat(d) - date.fromisoformat(prev)).days
            except ValueError:
                gap = 99
            n = n + 1 if gap == 1 else 1
            if n > best_n:
                best_n, best_end = n, d
            prev = d
        add("best streak", f"{best_n} days", "ended " + best_end)
    if tools:
        name, calls = tools.most_common(1)[0]
        add("favorite tool", f"{calls:,}", name)
    return out


def streak_of(days):
    d = date.today()
    if d.isoformat() not in days:
        d -= timedelta(days=1)
    n = 0
    while d.isoformat() in days:
        n += 1
        d -= timedelta(days=1)
    return n


def overview(records):
    if not records:
        return None
    now = time.time()
    total_cost = sum(r.cost for r in records)
    total_tok = sum(r.tin + r.tout + r.cw + r.cr for r in records)
    tin = sum(r.tin for r in records)
    tout = sum(r.tout for r in records)
    cw = sum(r.cw for r in records)
    cr = sum(r.cr for r in records)
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    busiest = max(days.items(), key=lambda kv: kv[1]["cost"]) if days else ("?", {"cost": 0})
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    peak_h = max(hours.items(), key=lambda kv: kv[1]["cost"]) if hours else (-1, {"cost": 0})
    models = aggregate(records, lambda r: r.model)
    top_m = max(models.items(), key=lambda kv: kv[1]["cost"]) if models else ("?", {"cost": 0})
    dd = sorted(days) if days else []
    t = datetime.now()
    today = t.strftime("%Y-%m-%d")
    m0 = datetime(t.year, t.month, 1).timestamp()
    mtd = sum(r.cost for r in records if r.t >= m0)
    dim = calendar.monthrange(t.year, t.month)[1]
    return {
        "cost": total_cost, "tok": total_tok,
        "tin": tin, "tout": tout, "cw": cw, "cr": cr,
        "msgs": len(records),
        "sessions": len({r.session for r in records}),
        "ndays": len(days),
        "first": dd[0] if dd else "?", "last": dd[-1] if dd else "?",
        "busiest_day": busiest, "peak_hour": peak_h,
        "top_model": top_m,
        "avg_day": total_cost / len(days) if days else 0,
        "today": days[today]["cost"] if today in days else 0.0,
        "hour_cost": sum(r.cost for r in records if r.t >= now - 3600),
        "saved": cache_saved(records),
        "mtd": mtd,
        "forecast": mtd / t.day * dim,
        "streak": streak_of(days),
        "cache_share": (cr / total_tok * 100) if total_tok else 0,
        "days": days,
    }


def fill_days(days):
    """Continuous (day, $) series from first to last day, with zeros for
    idle days so the sparkline's time axis does not lie."""
    if not days:
        return []
    ds = sorted(days)
    try:
        d0, d1 = date.fromisoformat(ds[0]), date.fromisoformat(ds[-1])
    except ValueError:
        return [(k, days[k]["cost"]) for k in ds]
    if (d1 - d0).days > 730:                  # guard against garbage timestamps
        return [(k, days[k]["cost"]) for k in ds]
    out = []
    d = d0
    while d <= d1:
        k = d.isoformat()
        a = days.get(k)
        out.append((k, a["cost"] if a else 0.0))
        d += timedelta(days=1)
    return out


# ---------------------------------------------------------------- periods

PERIODS = ["all", "today", "7 days", "30 days", "month"]


def cutoff(idx):
    if idx == 0:
        return None
    now = time.time()
    t = datetime.now()
    if idx == 1:
        return datetime(t.year, t.month, t.day).timestamp()
    if idx == 2:
        return now - 7 * 86400
    if idx == 3:
        return now - 30 * 86400
    if idx == 4:
        return datetime(t.year, t.month, 1).timestamp()
    return None


def apply_period(records, idx):
    c = cutoff(idx)
    if c is None:
        return records
    return [r for r in records if r.t >= c]


# ---------------------------------------------------------------- charts

FULL = "█"
EIGHTHS = "▏▎▍▌▋▊▉█"
SPARK = " ▁▂▃▄▅▆▇█"
SEP = "─"
BOX = "┌┐└┘─│"


def set_ascii_glyphs():
    """Fallback when UTF-8 is unavailable: draw with ASCII instead of ?."""
    global FULL, EIGHTHS, SPARK, SEP, BOX
    FULL = "#"
    EIGHTHS = " .:-=+*#"
    SPARK = " .:-=+*#@"
    SEP = "-"
    BOX = "++++-|"


def bar(frac, width):
    if width <= 0 or frac <= 0:
        return ""
    fb = frac * width
    n = int(fb)
    s = FULL * min(n, width)
    if n < width:
        rem = fb - n
        if rem > 0:
            s += EIGHTHS[min(int(rem * 8), 7)]
    return s


def sparkline(values, width):
    vals = values[-width:] if len(values) > width else values
    if not vals:
        return ""
    mx = max(vals) or 1
    return "".join(SPARK[min(int(v / mx * 8), 8)] for v in vals)


def spark_level(v, mx):
    if v <= 0:
        return 0
    return max(1, min(int(v / mx * 8), 8))


# ---------------------------------------------------------------- text mode

def print_text(co):
    records, titles, unknown = co.records, co.titles, co.unknown
    ov = overview(records)
    if not ov:
        print("no data")
        return
    print()
    print(f"  TOTAL   {ov['tok']:,} tokens   ≈ {money(ov['cost'])} (at API list prices)")
    print(f"          {ov['msgs']:,} messages · {ov['sessions']} chats · "
          f"{ov['ndays']} days ({ov['first']} … {ov['last']}) · "
          f"streak {ov['streak']} days")
    bd, bh = ov["busiest_day"], ov["peak_hour"]
    peak = f"{bh[0]:02d}:00" if bh[0] >= 0 else "—"
    print(f"          peak day: {bd[0]} ({money(bd[1]['cost'])}) · "
          f"peak hour: {peak} · ${ov['avg_day']:.2f}/day · "
          f"today {money(ov['today'])} · cache reads {ov['cache_share']:.1f}% of tokens")
    print(f"          cache saved ≈ {money(ov['saved'])} "
          f"(without cache ≈ {money(ov['cost'] + ov['saved'])}) · "
          f"month forecast {money(ov['forecast'])}")
    if unknown:
        print(f"          no price (counted as $0): {', '.join(sorted(unknown))}")

    def table(title, agg, namefn, sortkey="cost", limit=15, showmodel=False):
        rows = sorted(agg.items(), key=lambda kv: -kv[1][sortkey])[:limit]
        if not rows:
            return
        mx = max(tok(a) for _, a in rows) or 1
        print(f"\n  {title}")
        print("  " + "-" * 72)
        for k, a in rows:
            name = namefn(k, a)[:30]
            b = bar(tok(a) / mx, 14)
            mdl = f" {top_model(a).replace('claude-', ''):11}" if showmodel else ""
            print(f"  {name:30}{mdl} {b:14} {h(tok(a)):>7} {money(a['cost']):>11}")

    table("MODELS", aggregate(records, lambda r: r.model),
          lambda k, a: k.replace("claude-", ""))
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    table("DAYS (top by $)", days, lambda k, a: k)
    chats = aggregate(records, lambda r: r.session)
    table("CHATS", chats,
          lambda k, a: titles.get(k, "(" + k[:8] + ")"), showmodel=True)
    table("PROJECTS", aggregate(records, lambda r: r.project), lambda k, a: k)
    tools = tools_agg(records)
    if tools:
        rows = sorted(tools.items(), key=lambda kv: -kv[1]["calls"])[:15]
        mx = rows[0][1]["calls"] or 1
        print("\n  TOOLS (by calls)")
        print("  " + "-" * 72)
        for k, a in rows:
            print(f"  {k[:30]:30} {bar(a['calls'] / mx, 14):14} "
                  f"{a['calls']:>7,} {money(a['cost']):>11}")
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    print("\n  HOURS (by $, local time)")
    print("  " + "-" * 72)
    mxh = max((a["cost"] for a in hours.values()), default=1) or 1
    for hh in range(24):
        a = hours.get(hh)
        c = a["cost"] if a else 0
        print(f"  {hh:02d}:00  {bar(c / mxh, 40):40} {money(c):>10}")
    print()


def print_json(co):
    records, titles, unknown = co.records, co.titles, co.unknown
    ov = overview(records)

    def pack(agg, namefn=None, sort=True):
        items = agg.items()
        if sort:
            items = sorted(items, key=lambda kv: -kv[1]["cost"])
        out = []
        for k, a in items:
            d = {"key": str(k), "cost": round(a["cost"], 4), "tokens": tok(a),
                 "input": a["tin"], "output": a["tout"],
                 "cache_write": a["cw"], "cache_read": a["cr"], "msgs": a["msgs"]}
            if namefn:
                d["title"] = namefn(k)
            out.append(d)
        return out

    if not ov:
        json.dump({"total": None}, sys.stdout)
        print()
        return
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    data = {
        "total": {
            "cost": round(ov["cost"], 4), "tokens": ov["tok"],
            "input": ov["tin"], "output": ov["tout"],
            "cache_write": ov["cw"], "cache_read": ov["cr"],
            "msgs": ov["msgs"], "sessions": ov["sessions"],
            "days": ov["ndays"], "first": ov["first"], "last": ov["last"],
            "cache_saved": round(ov["saved"], 4),
            "forecast_month": round(ov["forecast"], 4),
            "streak_days": ov["streak"],
        },
        "unknown_models": sorted(unknown),
        "models": pack(aggregate(records, lambda r: r.model)),
        "days": pack(days, sort=False),
        "chats": pack(aggregate(records, lambda r: r.session),
                      namefn=lambda k: titles.get(k, "")),
        "projects": pack(aggregate(records, lambda r: r.project)),
        "tools": [
            {"key": k, "calls": a["calls"], "msgs": a["msgs"],
             "cost": round(a["cost"], 4)}
            for k, a in sorted(tools_agg(records).items(),
                               key=lambda kv: -kv[1]["calls"])
        ],
        "hours": pack(aggregate([r for r in records if r.hour >= 0],
                                lambda r: r.hour), sort=False),
    }
    json.dump(data, sys.stdout, ensure_ascii=False, indent=2)
    print()


# ---------------------------------------------------------------- GUI (browser)

def gui_payload(co, period, day=None):
    """All dashboard data in one payload; called on every poll.
    day=YYYY-MM-DD — day drill-down: the day chart keeps the period for
    context, everything else is computed for the selected day."""
    enabled = [r for r in co.records if CFG["sources"].get(r.src, True)]
    f_all = apply_period(enabled, period)
    f = [r for r in f_all if r.day == day] if day else f_all
    ov = overview(f)
    if not ov:
        return {"total": None, "period": period, "day": day,
                "root": claude_root(), "have_any": bool(enabled),
                "unknown": sorted(co.unknown)}
    days_agg = aggregate(f_all, lambda r: r.day)
    days_agg.pop("?", None)
    heat = [[0.0] * 24 for _ in range(7)]
    for r in f:
        if r.hour >= 0 and r.wd >= 0:
            heat[r.wd][r.hour] += r.cost
    models = [
        {"name": k.replace("claude-", ""), "cost": round(a["cost"], 2),
         "tok": tok(a), "out": a["tout"], "msgs": a["msgs"]}
        for k, a in sorted(aggregate(f, lambda r: r.model).items(),
                           key=lambda kv: -kv[1]["cost"])
    ]
    chats = [
        {"title": co.titles.get(k) or "(" + str(k)[:8] + ")",
         "project": next((r.project for r in f if r.session == k), "?"),
         "model": top_model(a).replace("claude-", ""),
         "cost": round(a["cost"], 2), "msgs": a["msgs"], "tok": tok(a)}
        for k, a in sorted(aggregate(f, lambda r: r.session).items(),
                           key=lambda kv: -kv[1]["cost"])[:10]
    ]
    tools = [
        {"name": k, "calls": a["calls"], "msgs": a["msgs"], "cost": round(a["cost"], 2)}
        for k, a in sorted(tools_agg(f).items(), key=lambda kv: -kv[1]["calls"])[:10]
    ]
    hours_agg = aggregate([r for r in f if r.hour >= 0], lambda r: r.hour)
    hours = [{"c": round(hours_agg[hh]["cost"], 2) if hh in hours_agg else 0,
              "m": hours_agg[hh]["msgs"] if hh in hours_agg else 0}
             for hh in range(24)]
    return {
        "period": period,
        "day": day,
        "today_str": datetime.now().strftime("%Y-%m-%d"),
        "total": {
            "cost": round(ov["cost"], 2), "tok": ov["tok"],
            "tin": ov["tin"], "tout": ov["tout"], "cw": ov["cw"], "cr": ov["cr"],
            "msgs": ov["msgs"], "sessions": ov["sessions"], "ndays": ov["ndays"],
            "first": ov["first"], "last": ov["last"],
            "avg_day": round(ov["avg_day"], 2), "today": round(ov["today"], 2),
            "hour_cost": round(ov["hour_cost"], 2), "saved": round(ov["saved"], 2),
            "mtd": round(ov["mtd"], 2), "forecast": round(ov["forecast"], 2),
            "streak": ov["streak"], "cache_share": round(ov["cache_share"], 1),
            "busiest_day": ov["busiest_day"][0],
            "busiest_cost": round(ov["busiest_day"][1]["cost"], 2),
            "peak_hour": ov["peak_hour"][0],
            "top_model": ov["top_model"][0].replace("claude-", ""),
        },
        "days": [{"d": d, "c": round(c, 2)} for d, c in fill_days(days_agg)][-120:],
        "heat": [[round(v, 2) for v in row] for row in heat],
        "models": models, "chats": chats, "tools": tools, "hours": hours,
        "unknown": sorted(co.unknown),
        "records": fun_records(enabled, co.titles),
        "year": _year_series(enabled),
        "version": VERSION,
        "update": UPDATE.get("info"),
    }


def _year_series(records):
    """365 days of cost for the year calendar (all-time, ignores period)."""
    daily = defaultdict(float)
    for r in records:
        if r.day != "?":
            daily[r.day] += r.cost
    end = date.today()
    out = []
    d = end - timedelta(days=364)
    while d <= end:
        k = d.isoformat()
        out.append({"d": k, "c": round(daily.get(k, 0.0), 2)})
        d += timedelta(days=1)
    return out


UPDATE = {"info": None}


def check_updates_loop():
    """Checks the latest GitHub release every 6 hours (when enabled)."""
    import urllib.request

    def ver(s):
        nums = re.findall(r"\d+", s or "")
        return tuple(int(x) for x in nums[:3]) or (0,)

    while True:
        if CFG.get("check_updates", True):
            try:
                req = urllib.request.Request(
                    "https://api.github.com/repos/ba31k/ccost/releases/latest",
                    headers={"User-Agent": "ccost/" + VERSION})
                with urllib.request.urlopen(req, timeout=8) as resp:
                    latest = json.loads(resp.read().decode("utf-8"))
                tag = latest.get("tag_name") or ""
                if ver(tag) > ver(VERSION):
                    UPDATE["info"] = {"tag": tag, "url": latest.get("html_url")}
                else:
                    UPDATE["info"] = None
            except Exception:
                pass
        time.sleep(6 * 3600)


