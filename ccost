#!/usr/bin/env python3
"""ccost — статистика токенов и стоимости (по прайсу API) всех сессий Claude Code.

Читает локальные JSONL из ~/.claude/projects/, дедуплицирует вызовы по message.id
(стриминг пишет несколько строк на сообщение с растущим usage — берём максимум,
иначе resume/fork удваивают цифры, а первая строка занижает output) и считает
стоимость по прайсу API, включая 1-часовой кэш (×2 против ×1.25 у 5-минутного).

  ccost           — интерактивный TUI (live-режим, мышь, вкладки, периоды)
  ccost report    — полный текстовый отчёт (он же фолбэк для пайпа/не-tty)
  ccost -r        — то же, что report
  ccost json      — агрегаты в JSON (для скриптов)
"""
import calendar
import glob
import json
import locale
import os
import re
import sys
import textwrap
import time
import unicodedata
from collections import Counter, defaultdict
from datetime import datetime, date, timedelta, timezone

