#!/usr/bin/env python3
"""ccost — статистика токенов и стоимости (по прайсу API) всех сессий Claude Code.

Читает локальные JSONL из ~/.claude/projects/, дедуплицирует вызовы по message.id
(иначе resume/fork сессий удваивают цифры) и считает стоимость по прайсу API.

  ccost           — интерактивный TUI (вкладки, периоды, сортировка, графики)
  ccost report    — полный текстовый отчёт (он же фолбэк для пайпа/не-tty)
  ccost -r        — то же, что report
"""
import curses
import glob
import json
import locale
import os
import sys
import time
from collections import defaultdict
from datetime import datetime, timezone

# ---------------------------------------------------------------- прайс / цены

# $ за 1M токенов (input, output) — стандартный прайс API
PRICE = {
    "claude-fable-5":            (10, 50),
    "claude-opus-4-8":           (5, 25),
    "claude-opus-4-7":           (5, 25),
    "claude-opus-4-6":           (5, 25),
    "claude-opus-4-5":           (5, 25),
    "claude-sonnet-5":           (3, 15),
    "claude-sonnet-4-6":         (3, 15),
    "claude-haiku-4-5":          (1, 5),
    "claude-haiku-4-5-20251001": (1, 5),
}
CACHE_WRITE = 1.25   # запись в кэш (5-мин ephemeral) = 1.25× input
CACHE_READ = 0.10    # чтение из кэша = 0.1× input

ROOT = os.path.expanduser("~/.claude/projects")

TS_FORMATS = ("%Y-%m-%dT%H:%M:%S.%fZ", "%Y-%m-%dT%H:%M:%SZ")


def cost_of(model, tin, tout, cw, cr):
    pin, pout = PRICE.get(model, (0, 0))
    ci = pin / 1e6
    return tin * ci + tout * pout / 1e6 + cw * ci * CACHE_WRITE + cr * ci * CACHE_READ


def parse_ts(s):
    if not s:
        return 0.0
    for fmt in TS_FORMATS:
        try:
            return datetime.strptime(s, fmt).replace(tzinfo=timezone.utc).timestamp()
        except ValueError:
            continue
    return 0.0


def h(n):
    """Человекочитаемый размер токенов: 1234567 -> 1.2M"""
    for unit, size in (("B", 1e9), ("M", 1e6), ("K", 1e3)):
        if n >= size:
            return f"{n / size:.1f}{unit}"
    return str(int(n))


def money(x):
    return f"${x:,.2f}"


# ---------------------------------------------------------------- сбор данных

class Rec:
    __slots__ = ("t", "model", "session", "project",
                 "tin", "tout", "cw", "cr", "cost", "day", "hour")


def collect():
    """Проходит все JSONL, дедуплицирует по message.id.
    Возвращает (records, titles: session->str)."""
    seen = set()
    records = []
    titles = {}
    for fp in glob.glob(os.path.join(ROOT, "**", "*.jsonl"), recursive=True):
        try:
            fh = open(fp, errors="replace")
        except OSError:
            continue
        with fh:
            for line in fh:
                if '"usage"' not in line and '"type":"user"' not in line \
                        and '"type": "user"' not in line:
                    continue
                try:
                    o = json.loads(line)
                except ValueError:
                    continue
                typ = o.get("type")
                if typ == "user":
                    _maybe_title(o, titles)
                    continue
                if typ != "assistant":
                    continue
                m = o.get("message", {})
                u = m.get("usage")
                mid = m.get("id")
                if not u or mid in seen:
                    continue
                seen.add(mid)
                r = Rec()
                r.model = m.get("model", "unknown")
                r.session = o.get("sessionId", "?")
                cwd = o.get("cwd") or ""
                r.project = os.path.basename(cwd) or "?"
                r.tin = u.get("input_tokens", 0)
                r.tout = u.get("output_tokens", 0)
                r.cw = u.get("cache_creation_input_tokens", 0)
                r.cr = u.get("cache_read_input_tokens", 0)
                if r.tin + r.tout + r.cw + r.cr == 0:
                    continue                       # синтетические/пустые сообщения
                r.cost = cost_of(r.model, r.tin, r.tout, r.cw, r.cr)
                r.t = parse_ts(o.get("timestamp"))
                if r.t:
                    lt = datetime.fromtimestamp(r.t)
                    r.day = lt.strftime("%Y-%m-%d")
                    r.hour = lt.hour
                else:
                    r.day, r.hour = "?", -1
                records.append(r)
    return records, titles


def _maybe_title(o, titles):
    if o.get("isSidechain"):
        return
    sid = o.get("sessionId")
    if not sid or sid in titles:
        return
    c = o.get("message", {}).get("content")
    text = None
    if isinstance(c, str):
        text = c
    elif isinstance(c, list):
        for b in c:
            if isinstance(b, dict) and b.get("type") == "text":
                text = b.get("text")
                break
    if not text:
        return
    text = " ".join(text.split())
    if text and not text.startswith("<") and not text.startswith("Caveat"):
        titles[sid] = text[:80]


# ---------------------------------------------------------------- агрегация

def tok(a):
    return a["tin"] + a["tout"] + a["cw"] + a["cr"]


def aggregate(records, keyfn):
    d = {}
    for r in records:
        k = keyfn(r)
        a = d.get(k)
        if a is None:
            a = d[k] = {"tin": 0, "tout": 0, "cw": 0, "cr": 0,
                        "cost": 0.0, "msgs": 0, "mc": defaultdict(int)}
        a["tin"] += r.tin
        a["tout"] += r.tout
        a["cw"] += r.cw
        a["cr"] += r.cr
        a["cost"] += r.cost
        a["msgs"] += 1
        a["mc"][r.model] += r.tin + r.tout + r.cw + r.cr
    return d


def top_model(a):
    return max(a["mc"].items(), key=lambda kv: kv[1])[0] if a["mc"] else "?"


def overview(records):
    if not records:
        return None
    total_cost = sum(r.cost for r in records)
    total_tok = sum(r.tin + r.tout + r.cw + r.cr for r in records)
    tin = sum(r.tin for r in records)
    tout = sum(r.tout for r in records)
    cw = sum(r.cw for r in records)
    cr = sum(r.cr for r in records)
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    busiest = max(days.items(), key=lambda kv: kv[1]["cost"]) if days else ("?", {"cost": 0})
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    peak_h = max(hours.items(), key=lambda kv: kv[1]["cost"]) if hours else (-1, {"cost": 0})
    models = aggregate(records, lambda r: r.model)
    top_m = max(models.items(), key=lambda kv: kv[1]["cost"]) if models else ("?", {"cost": 0})
    dd = sorted(days) if days else []
    return {
        "cost": total_cost, "tok": total_tok,
        "tin": tin, "tout": tout, "cw": cw, "cr": cr,
        "msgs": len(records),
        "sessions": len({r.session for r in records}),
        "ndays": len(days),
        "first": dd[0] if dd else "?", "last": dd[-1] if dd else "?",
        "busiest_day": busiest, "peak_hour": peak_h,
        "top_model": top_m,
        "avg_day": total_cost / len(days) if days else 0,
        "cache_share": (cr / total_tok * 100) if total_tok else 0,
        "days": days,
    }


# ---------------------------------------------------------------- периоды

PERIODS = ["всё", "сегодня", "7 дней", "30 дней"]


def cutoff(idx):
    if idx == 0:
        return None
    now = time.time()
    if idx == 1:
        t = datetime.now()
        return datetime(t.year, t.month, t.day).timestamp()
    if idx == 2:
        return now - 7 * 86400
    if idx == 3:
        return now - 30 * 86400
    return None


def apply_period(records, idx):
    c = cutoff(idx)
    if c is None:
        return records
    return [r for r in records if r.t >= c]


# ---------------------------------------------------------------- графики

FULL = "█"
EIGHTHS = "▏▎▍▌▋▊▉█"
SPARK = " ▁▂▃▄▅▆▇█"
SEP = "─"


def set_ascii_glyphs():
    """Фолбэк, когда UTF-8 недоступен: рисуем графику на ASCII, а не на ?."""
    global FULL, EIGHTHS, SPARK, SEP
    FULL = "#"
    EIGHTHS = " .:-=+*#"
    SPARK = " .:-=+*#@"
    SEP = "-"


def bar(frac, width):
    if width <= 0 or frac <= 0:
        return ""
    fb = frac * width
    n = int(fb)
    s = FULL * min(n, width)
    if n < width:
        rem = fb - n
        if rem > 0:
            s += EIGHTHS[min(int(rem * 8), 7)]
    return s


def sparkline(values, width):
    vals = values[-width:] if len(values) > width else values
    if not vals:
        return ""
    mx = max(vals) or 1
    return "".join(SPARK[min(int(v / mx * 8), 8)] for v in vals)


# ---------------------------------------------------------------- текстовый режим

def print_text(records, titles):
    ov = overview(records)
    if not ov:
        print("нет данных")
        return
    print()
    print(f"  ВСЕГО   {ov['tok']:,} токенов   ≈ {money(ov['cost'])} (по прайсу API)")
    print(f"          {ov['msgs']:,} сообщений · {ov['sessions']} чатов · "
          f"{ov['ndays']} дней ({ov['first']} … {ov['last']})")
    bd, bh = ov["busiest_day"], ov["peak_hour"]
    print(f"          пик дня: {bd[0]} ({money(bd[1]['cost'])}) · "
          f"пик часа: {bh[0]:02d}:00 · ${ov['avg_day']:.2f}/день · "
          f"кэш-чтения {ov['cache_share']:.1f}% токенов")

    def table(title, agg, namefn, sortkey="cost", limit=15, showmodel=False):
        rows = sorted(agg.items(), key=lambda kv: -kv[1][sortkey])[:limit]
        if not rows:
            return
        mx = max(tok(a) for _, a in rows) or 1
        print(f"\n  {title}")
        print("  " + "-" * 72)
        for k, a in rows:
            name = namefn(k, a)[:30]
            b = bar(tok(a) / mx, 14)
            mdl = f" {top_model(a).replace('claude-', ''):11}" if showmodel else ""
            print(f"  {name:30}{mdl} {b:14} {h(tok(a)):>7} {money(a['cost']):>11}")

    table("МОДЕЛИ", aggregate(records, lambda r: r.model),
          lambda k, a: k.replace("claude-", ""))
    days = aggregate(records, lambda r: r.day)
    days.pop("?", None)
    table("ДНИ (топ по $)", days, lambda k, a: k)
    chats = aggregate(records, lambda r: r.session)
    table("ЧАТЫ", chats,
          lambda k, a: titles.get(k, "(" + k[:8] + ")"), showmodel=True)
    table("ПРОЕКТЫ", aggregate(records, lambda r: r.project), lambda k, a: k)
    hours = aggregate([r for r in records if r.hour >= 0], lambda r: r.hour)
    print("\n  ЧАСЫ (по $, локальное время)")
    print("  " + "-" * 72)
    mxh = max((a["cost"] for a in hours.values()), default=1) or 1
    for hh in range(24):
        a = hours.get(hh)
        c = a["cost"] if a else 0
        print(f"  {hh:02d}:00  {bar(c / mxh, 40):40} {money(c):>10}")
    print()


# ---------------------------------------------------------------- TUI (curses)

TABS = ["Обзор", "Модели", "Дни", "Чаты", "Проекты", "Часы"]


class App:
    def __init__(self, records, titles):
        self.records = records
        self.titles = titles
        self.tab = 0
        self.period = 0
        self.sortkey = "cost"          # cost | tok
        self.sel = [0] * len(TABS)
        self.recompute()

    def recompute(self):
        self.f = apply_period(self.records, self.period)
        self.ov = overview(self.f)
        self.ag_models = aggregate(self.f, lambda r: r.model)
        days = aggregate(self.f, lambda r: r.day)
        days.pop("?", None)
        self.ag_days = days
        self.ag_chats = aggregate(self.f, lambda r: r.session)
        self.ag_proj = aggregate(self.f, lambda r: r.project)
        self.ag_hours = aggregate([r for r in self.f if r.hour >= 0], lambda r: r.hour)

    def sorted_rows(self, agg):
        if self.sortkey == "tok":
            return sorted(agg.items(), key=lambda kv: -tok(kv[1]))
        return sorted(agg.items(), key=lambda kv: -kv[1]["cost"])

    def rows_for(self, tab):
        if tab == 1:
            return self.sorted_rows(self.ag_models)
        if tab == 2:
            return sorted(self.ag_days.items())          # по дате
        if tab == 3:
            return self.sorted_rows(self.ag_chats)
        if tab == 4:
            return self.sorted_rows(self.ag_proj)
        if tab == 5:
            return [(hh, self.ag_hours.get(hh)) for hh in range(24)]
        return []

    # ------------------------------------------------------------ цикл
    def run(self, scr):
        curses.curs_set(0)
        scr.timeout(-1)
        self._init_colors()
        while True:
            self.draw(scr)
            ch = scr.getch()
            if not self.handle(ch):
                break

    def _init_colors(self):
        # Роли: dim (второстепенный текст), head (заголовки), money ($),
        # bar (графики), tab (активная вкладка). Значение каждой роли — готовый
        # curses-атрибут, который можно | с A_REVERSE и т.п.
        self.c = defaultdict(int)
        no_color = os.environ.get("NO_COLOR") is not None
        if no_color or not curses.has_colors():
            # без цвета — держим структуру на атрибутах
            self.c["dim"] = curses.A_DIM
            self.c["head"] = curses.A_BOLD
            self.c["money"] = curses.A_BOLD
            self.c["bar"] = 0
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD
            return
        curses.start_color()
        try:
            curses.use_default_colors()   # фон = родной фон терминала
            bg = -1
        except curses.error:
            bg = curses.COLOR_BLACK
        ncolors = getattr(curses, "COLORS", 8)
        if ncolors >= 256:
            # аккуратные оттенки, читаемые и на тёмном, и на светлом фоне
            specs = [
                ("dim",   245, bg, 0),                 # серый, а не синий
                ("head",  179, bg, curses.A_BOLD),     # тёпло-жёлтый
                ("money", 71,  bg, 0),                 # зелёный
                ("bar",   37,  bg, 0),                 # бирюзовый
                ("tab",   16,  37, curses.A_BOLD),     # тёмный на бирюзе
                ("sel",   231, 24, curses.A_BOLD),     # выделение: белый на синем
            ]
        else:
            # 8/16 цветов: серого нет — берём белый + A_DIM
            specs = [
                ("dim",   curses.COLOR_WHITE,  bg, curses.A_DIM),
                ("head",  curses.COLOR_YELLOW, bg, curses.A_BOLD),
                ("money", curses.COLOR_GREEN,  bg, 0),
                ("bar",   curses.COLOR_CYAN,   bg, 0),
                ("tab",   curses.COLOR_BLACK,  curses.COLOR_CYAN, curses.A_BOLD),
                ("sel",   curses.COLOR_WHITE,  curses.COLOR_BLUE, curses.A_BOLD),
            ]
        for i, (name, fg, b, extra) in enumerate(specs, start=1):
            try:
                curses.init_pair(i, fg, b)
                self.c[name] = curses.color_pair(i) | extra
            except curses.error:
                self.c[name] = extra
        # если пары не создались — держим читаемость через инверсию
        if not self.c["tab"]:
            self.c["tab"] = curses.A_REVERSE | curses.A_BOLD
        if not self.c["sel"]:
            self.c["sel"] = curses.A_REVERSE | curses.A_BOLD

    def handle(self, ch):
        if ch in (ord("q"), 27):
            return False
        n = len(TABS)
        if ch in (curses.KEY_RIGHT, ord("l"), ord("]"), ord("\t")):
            self.tab = (self.tab + 1) % n
        elif ch in (curses.KEY_LEFT, ord("h"), ord("[")):
            self.tab = (self.tab - 1) % n
        elif ord("1") <= ch <= ord("6"):
            self.tab = ch - ord("1")
        elif ch in (curses.KEY_DOWN, ord("j")):
            self.sel[self.tab] += 1
        elif ch in (curses.KEY_UP, ord("k")):
            self.sel[self.tab] = max(0, self.sel[self.tab] - 1)
        elif ch == curses.KEY_NPAGE:
            self.sel[self.tab] += 10
        elif ch == curses.KEY_PPAGE:
            self.sel[self.tab] = max(0, self.sel[self.tab] - 10)
        elif ch in (curses.KEY_HOME, ord("g")):
            self.sel[self.tab] = 0
        elif ch == ord("f"):
            self.period = (self.period + 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("F"):
            self.period = (self.period - 1) % len(PERIODS)
            self.recompute()
        elif ch == ord("s"):
            self.sortkey = "tok" if self.sortkey == "cost" else "cost"
        return True

    def add(self, scr, y, x, s, attr=0):
        maxy, maxx = scr.getmaxyx()
        if y < 0 or y >= maxy or x < 0 or x >= maxx:
            return
        s = s[: maxx - x - 1]
        try:
            scr.addstr(y, x, s, attr)
        except curses.error:
            pass

    def draw(self, scr):
        scr.erase()
        maxy, maxx = scr.getmaxyx()
        head = self.ov
        cost = money(head["cost"]) if head else "$0.00"
        toks = h(head["tok"]) if head else "0"
        self.add(scr, 0, 1, "ccost", curses.A_BOLD)
        right = f"{toks} токенов · {cost} · период: {PERIODS[self.period]}"
        self.add(scr, 0, max(8, maxx - len(right) - 2), right, self.c["dim"])
        # вкладки
        x = 1
        for i, name in enumerate(TABS):
            label = f" {i+1}·{name} "
            attr = self.c["tab"] | curses.A_BOLD if i == self.tab else curses.A_DIM
            self.add(scr, 1, x, label, attr)
            x += len(label) + 1
        self.add(scr, 2, 1, SEP * (maxx - 2), self.c["dim"])
        body_top = 3
        body_h = maxy - body_top - 1
        if not head:
            self.add(scr, body_top + 1, 2,
                     "нет данных за период «%s»" % PERIODS[self.period])
        elif self.tab == 0:
            self.draw_overview(scr, body_top, body_h, maxx)
        elif self.tab == 5:
            self.draw_hours(scr, body_top, body_h, maxx)
        else:
            self.draw_table(scr, body_top, body_h, maxx)
        foot = ("←→/1-6 вкладки · ↑↓ скролл · f период · s сорт(%s) · q выход"
                % self.sortkey)
        self.add(scr, maxy - 1, 1, foot, self.c["dim"])
        scr.refresh()

    def draw_overview(self, scr, top, h_, maxx):
        o = self.ov
        y = top + 1
        self.add(scr, y, 2, money(o["cost"]), self.c["money"] | curses.A_BOLD)
        self.add(scr, y, 16, f"{o['tok']:,} токенов", curses.A_BOLD)
        y += 2
        lines = [
            ("сообщений", f"{o['msgs']:,}"),
            ("чатов", f"{o['sessions']:,}"),
            ("активных дней", f"{o['ndays']}  ({o['first']} … {o['last']})"),
            ("в среднем / день", money(o["avg_day"])),
            ("пик дня", f"{o['busiest_day'][0]}  ({money(o['busiest_day'][1]['cost'])})"),
            ("пик часа", f"{o['peak_hour'][0]:02d}:00"),
            ("топ-модель", o["top_model"][0].replace("claude-", "")),
            ("кэш-чтения", f"{o['cache_share']:.1f}% всех токенов"),
        ]
        for name, val in lines:
            self.add(scr, y, 2, f"{name:>18} :", self.c["dim"])
            self.add(scr, y, 23, val)
            y += 1
        y += 1
        self.add(scr, y, 2, "токены:", self.c["head"])
        self.add(scr, y, 12,
                 f"input {h(o['tin'])} · cache-wr {h(o['cw'])} · "
                 f"cache-rd {h(o['cr'])} · output {h(o['tout'])}")
        y += 2
        self.add(scr, y, 2, "стоимость по дням:", self.c["head"])
        y += 1
        days = sorted(self.ag_days.items())
        if days:
            vals = [a["cost"] for _, a in days]
            spark = sparkline(vals, min(maxx - 6, 80))
            self.add(scr, y, 2, spark, self.c["bar"])
            y += 1
            self.add(scr, y, 2,
                     f"{days[0][0]}  →  {days[-1][0]}   макс ${max(vals):.2f}/день",
                     self.c["dim"])

    def draw_table(self, scr, top, h_, maxx):
        rows = self.rows_for(self.tab)
        sel = self.sel[self.tab] = min(self.sel[self.tab], max(0, len(rows) - 1))
        off = window(sel, len(rows), h_ - 1)
        mx = max((tok(a) for _, a in rows), default=1) or 1
        title = {1: "модель", 2: "день", 3: "чат", 4: "проект"}[self.tab]
        self.add(scr, top, 2, title, self.c["head"])
        self.add(scr, top, maxx - 34, "input cache  out", self.c["head"] | curses.A_DIM)
        self.add(scr, top, maxx - 12, "$", self.c["head"])
        namew = max(12, maxx - 52)
        for i in range(off, min(len(rows), off + h_ - 1)):
            k, a = rows[i]
            y = top + 1 + (i - off)
            selected = i == sel
            if selected:                         # сплошная подсветка на всю ширину
                self.add(scr, y, 1, " " * (maxx - 2), self.c["sel"])
            a_txt = self.c["sel"] if selected else 0
            a_bar = self.c["sel"] if selected else self.c["bar"]
            a_dim = self.c["sel"] if selected else self.c["dim"]
            a_mon = self.c["sel"] if selected else self.c["money"]
            if self.tab == 1:
                name = k.replace("claude-", "")
            elif self.tab == 3:
                name = self.titles.get(k) or f"({k[:8]})"
            else:
                name = k
            mark = "> " if selected else "  "
            self.add(scr, y, 1, f"{mark}{name}"[:namew + 1].ljust(namew + 1), a_txt)
            bx = 2 + namew + 1
            self.add(scr, y, bx, bar(tok(a) / mx, 12), a_bar)
            self.add(scr, y, maxx - 34,
                     f"{h(a['tin']):>5}{h(a['cw']):>6}{h(a['tout']):>6}", a_dim)
            self.add(scr, y, maxx - 13, f"{money(a['cost']):>11}", a_mon)
        if len(rows) > h_ - 1:
            self.add(scr, top, maxx - 46, f"[{sel + 1}/{len(rows)}]", self.c["dim"])

    def draw_hours(self, scr, top, h_, maxx):
        self.add(scr, top, 2, "активность по часам (локальное время)", self.c["head"])
        mxc = max((a["cost"] for a in self.ag_hours.values()), default=1) or 1
        bw = max(10, maxx - 30)
        for hh in range(24):
            y = top + 1 + hh
            if y >= top + h_:
                break
            a = self.ag_hours.get(hh)
            c = a["cost"] if a else 0
            msgs = a["msgs"] if a else 0
            self.add(scr, y, 2, f"{hh:02d}:00", self.c["dim"])
            self.add(scr, y, 8, bar(c / mxc, bw), self.c["bar"])
            self.add(scr, y, maxx - 20, f"{msgs:>5} msg {money(c):>9}", self.c["money"])


def window(sel, n, h_):
    if n <= h_:
        return 0
    return max(0, min(sel - h_ // 2, n - h_))


# ---------------------------------------------------------------- main

def _codeset():
    # реальный codeset LC_CTYPE — именно его смотрит ncurses (в отличие от
    # getpreferredencoding, который на macOS врёт «UTF-8» даже под локалью C)
    try:
        return (locale.nl_langinfo(locale.CODESET) or "").upper()
    except (AttributeError, ValueError):
        return (locale.getpreferredencoding(False) or "").upper()


def setup_output():
    """Локаль ставим ДО curses.initscr (иначе бары рендерятся как «?»).
    Пытаемся получить UTF-8; если не вышло — переходим на ASCII-графику."""
    utf8 = False
    for loc in ("", "en_US.UTF-8", "C.UTF-8", "en_US.utf8", "C.utf8", "UTF-8"):
        try:
            locale.setlocale(locale.LC_ALL, loc)
        except locale.Error:
            continue
        if "UTF" in _codeset().replace("-", ""):
            utf8 = True
            break
    try:                      # текстовый режим: не падать на не-UTF8 stdout
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    except Exception:
        pass
    if os.environ.get("CCOST_ASCII") or not utf8:
        set_ascii_glyphs()


def main():
    arg = sys.argv[1] if len(sys.argv) > 1 else ""
    setup_output()
    records, titles = collect()
    want_text = arg in ("report", "-r", "--report", "text")
    if want_text or not sys.stdout.isatty():
        print_text(records, titles)
        return
    try:
        curses.wrapper(App(records, titles).run)
    except Exception as e:  # фолбэк на текст при любой проблеме с curses
        sys.stderr.write(f"TUI недоступен ({e}); текстовый отчёт:\n")
        print_text(records, titles)


if __name__ == "__main__":
    main()
